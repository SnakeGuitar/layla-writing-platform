# ===========================================
# Layla — Variables compartidas entre las 3 VMs
# ===========================================
# Copiar este archivo a .env.shared y rellenar los valores reales.
# .env.shared esta gitignorado por seguridad.

# --- SQL Server ---
SQL_SERVER=192.168.56.10
SQL_PORT=1433
SQL_USERNAME=sa
SQL_PASSWORD=CHANGE_ME_strong_password
SQL_DATABASE=LaylaCore
MSSQL_MEM_LIMIT=2048

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=layla
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_strong_password
MONGO_PORT=27017

# --- Neo4j ---
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_strong_password
NEO4J_BROWSER_PORT=7474
NEO4J_BOLT_PORT=7687

# --- RabbitMQ ---
RABBIT_HostName=192.168.56.10
RABBIT_USER=layla
RABBIT_PASSWORD=CHANGE_ME_strong_password
RABBIT_PORT=5672
RABBIT_MANAGEMENT_PORT=15672

# --- Worldbuilding ---
WORLDBUILDING_PORT_HTTP=3001
WORLDBUILDING_PORT_HTTPS=3000
WORLDBUILDING_ALLOWED_ORIGINS=http://192.168.56.12:5000,https://192.168.56.11:5288

# --- Core API ---
CORE_PORT_HTTPS=7166
CORE_PORT_HTTP=5287
CORE_ENVIRONMENT=Production

# --- Web Client ---
WEB_PORT_HTTPS=5288
WEB_PORT_HTTP=5289

# --- JWT ---
# Generar con: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_min_32_characters_long_secret_key
JWT_SECRET_REFRESH=CHANGE_ME_min_32_characters_long_refresh_key
JWT_ISSUER=layla-core
JWT_AUDIENCE=layla-clients
JWT_ACCESS_TOKEN_EXPIRY=1440
JWT_REFRESH_TOKEN_EXPIRY=10080
