# Layla — Vagrantfile
# Provisiona 3 VMs (data, apps, edge) con Docker + Compose vía Puppet.
# Uso desde Windows: cd deploy && vagrant up
Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"
  config.vm.box_check_update = false

  # El repo completo queda accesible en /vagrant dentro de cada VM
  # (Vagrant lo monta automáticamente desde el folder padre del Vagrantfile)
  config.vm.synced_folder "..", "/vagrant", type: "virtualbox"

  config.vm.provider "virtualbox" do |vb|
    vb.linked_clone = true
    vb.gui = false
  end

  # ---------- VM1: layla-data ----------
  config.vm.define "data" do |m|
    m.vm.hostname = "layla-data"
    m.vm.network "private_network", ip: "192.168.56.10"
    m.vm.provider "virtualbox" do |vb|
      vb.name   = "layla-data"
      vb.memory = 3072
      vb.cpus   = 2
    end
    m.vm.provision "shell", path: "puppet/bootstrap.sh"
    m.vm.provision "puppet" do |p|
      p.manifests_path  = "puppet/manifests"
      p.manifest_file   = "data.pp"
      p.module_path     = "puppet/modules"
    end
  end

  # ---------- VM2: layla-apps ----------
  config.vm.define "apps" do |m|
    m.vm.hostname = "layla-apps"
    m.vm.network "private_network", ip: "192.168.56.11"
    m.vm.provider "virtualbox" do |vb|
      vb.name   = "layla-apps"
      vb.memory = 3072
      vb.cpus   = 2
    end
    m.vm.provision "shell", path: "puppet/bootstrap.sh"
    m.vm.provision "puppet" do |p|
      p.manifests_path  = "puppet/manifests"
      p.manifest_file   = "apps.pp"
      p.module_path     = "puppet/modules"
    end
  end

  # ---------- VM3: layla-edge ----------
  config.vm.define "edge" do |m|
    m.vm.hostname = "layla-edge"
    m.vm.network "private_network", ip: "192.168.56.12"
    m.vm.network "forwarded_port", guest: 5000, host: 5000
    m.vm.provider "virtualbox" do |vb|
      vb.name   = "layla-edge"
      vb.memory = 1024
      vb.cpus   = 1
    end
    m.vm.provision "shell", path: "puppet/bootstrap.sh"
    m.vm.provision "puppet" do |p|
      p.manifests_path  = "puppet/manifests"
      p.manifest_file   = "edge.pp"
      p.module_path     = "puppet/modules"
    end
  end
end
