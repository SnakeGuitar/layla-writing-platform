{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"Kestrel": {
		"Endpoints": {
			"Http": {
				"Url": "http://0.0.0.0:5000",
				"Protocols": "Http1AndHttp2"
			}
		}
	},
	"ReverseProxy": {
		"Routes": {
			"tokens-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/api/tokens/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/tokens/{**catch-all}" }]
			},
			"projects-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/api/projects/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/projects/{**catch-all}" }]
			},
			"users-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/api/users/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/users/{**catch-all}" }]
			},

			"wiki-route": {
				"ClusterId": "worldbuilding-cluster",
				"Match": { "Path": "/api/wiki/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/wiki/{**catch-all}" }]
			},
			"graph-route": {
				"ClusterId": "worldbuilding-cluster",
				"Match": { "Path": "/api/graph/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/graph/{**catch-all}" }]
			},
			"manuscripts-route": {
				"ClusterId": "worldbuilding-cluster",
				"Match": { "Path": "/api/manuscripts/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/api/manuscripts/{**catch-all}" }]
			},

			"voice-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/hubs/voice/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/hubs/voice/{**catch-all}" }]
			},
			"presence-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/hubs/presence/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/hubs/presence/{**catch-all}" }]
			},

			"grpc-route": {
				"ClusterId": "core-cluster",
				"Match": { "Path": "/grpc/{**catch-all}" },
				"Transforms": [{ "PathPattern": "/grpc/{**catch-all}" }]
			}
		}
	},
	"Clusters": {
		"core-cluster": {
			"HttpClient": {
				"WebSocketEnabled": true,
				"RequestVersion": "2.0",
				"RequestVersionOrHigher": "2.0"
			},
			"HealthCheck": {
				"Active": {
					"Enabled": "true",
					"Interval": "00:00:15",
					"Timeout": "00:00:05",
					"Policy": "MinReplicas",
					"Path": "/health"
				},
				"Passive": {
					"Enabled": "true",
					"Policy": "MinReplicas",
					"ReactivationPeriod": "00:00:30"
				}
			},
			"Destinations": {
				"primary": { "Address": "http://server-core:5287" }
			}
		},

		"worldbuilding-cluster": {
			"HealthCheck": {
				"Active": {
					"Enabled": "true",
					"Interval": "00:00:15",
					"Timeout": "00:00:05",
					"Policy": "MinReplicas",
					"Path": "/health"
				},
				"Passive": {
					"Enabled": "true",
					"Policy": "MinReplicas",
					"ReactivationPeriod": "00:00:30"
				}
			},
			"Destinations": {
				"primary": { "Address": "http://layla-worldbuilding:3000" }
			}
		}
	}
}
