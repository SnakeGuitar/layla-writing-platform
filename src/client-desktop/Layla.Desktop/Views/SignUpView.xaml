<Page x:Class="Layla.Desktop.Views.SignUpView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fw="clr-namespace:SourceChord.FluentWPF;assembly=FluentWPF"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      ShowsNavigationUI="False"
      Title="Sign Up"
      Background="{DynamicResource WindowBackground}"
      Foreground="{DynamicResource PrimaryText}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid Width="360" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <Grid.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Opacity="0.5" Color="Black"/>
            </Grid.Effect>
            
            <Border CornerRadius="16" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                <fw:AcrylicPanel Background="{DynamicResource ControlBackground}" TintColor="{DynamicResource AcrylicTintColor}" TintOpacity="{DynamicResource AcrylicTintOpacity}">
                    <StackPanel Margin="40">
                        <TextBlock Text="Layla" FontSize="36" FontWeight="ExtraBold" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource AccentColor}" Margin="0,0,0,10"/>
                        <TextBlock Text="Create your author account" FontSize="14" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,30"/>

                        <TextBlock Text="EMAIL" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                        <TextBox x:Name="EmailTextBox" Padding="10" Background="Transparent" 
                                 Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,15"
                                 materialDesign:HintAssist.Hint="hello@layla.app" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="DISPLAY NAME" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                        <TextBox x:Name="DisplayNameTextBox" Padding="10" Background="Transparent" 
                                 Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,15"
                                 materialDesign:HintAssist.Hint="Author Name" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="PASSWORD" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="PasswordBox" Padding="10" Background="Transparent" 
                                     Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" Margin="0,0,0,25"
                                     materialDesign:HintAssist.Hint="••••••••" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBlock x:Name="StatusText" Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" TextAlignment="Center"
                                   Text="{Binding StatusMessage}"/>

                        <Button x:Name="SignUpButton" Content="{Binding SignUpButtonContent}" Height="45" FontSize="16" FontWeight="SemiBold"
                                Background="{DynamicResource AccentColor}" Foreground="White" 
                                BorderThickness="0" Cursor="Hand" Command="{Binding SignUpCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                materialDesign:ButtonAssist.CornerRadius="8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock Text="Already have an account? " Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Text="Sign in" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" 
                                       Cursor="Hand" MouseLeftButtonDown="NavigateToLogin_Click"/>
                        </StackPanel>
                    </StackPanel>
                </fw:AcrylicPanel>
            </Border>
        </Grid>
    </Grid>
</Page>