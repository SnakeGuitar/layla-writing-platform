<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- ================================================================= -->
    <!-- DESIGN TOKENS (COLORS)                                            -->
    <!-- ================================================================= -->
    <Color x:Key="CyberBgPrimaryColor">#020204</Color>
    <Color x:Key="CyberBgSecondaryColor">#0B0B0E</Color>
    <Color x:Key="CyberBgElevatedColor">#0E0D14</Color>
    <Color x:Key="CyberBorderSubtleColor">#1A1A22</Color>
    <Color x:Key="CyberBorderActiveColor">#00F0FF</Color>
    <Color x:Key="CyberTextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="CyberTextSecondaryColor">#94A3B8</Color>
    <Color x:Key="CyberTextDisabledColor">#475569</Color>
    
    <!-- ACCENTS (CYBER BRUTALIST & AURORA) -->
    <Color x:Key="CyberAccentPrimaryColor">#00F0FF</Color> <!-- Electric Cyan -->
    <Color x:Key="CyberAccentSecondaryColor">#8B5CF6</Color> <!-- Royal Violet -->
    <Color x:Key="CyberAccentAlertColor">#CCFF00</Color> <!-- Toxic Lime Green -->
    <Color x:Key="CyberAccentGlowColor">#1A00F0FF</Color> <!-- 10% Cyan Glow -->
    <Color x:Key="CyberAccentWarningColor">#EF4444</Color> <!-- Red Alert -->

    <!-- BRUSHES -->
    <!-- Stunning Sweeping Deep Aurora Glow Background -->
    <LinearGradientBrush x:Key="CyberBgPrimaryBrush" StartPoint="0,0" EndPoint="1.2,1.2">
        <GradientStop Color="#020204" Offset="0.0" />
        <GradientStop Color="#0C071A" Offset="0.35" />
        <GradientStop Color="#040F22" Offset="0.75" />
        <GradientStop Color="#010102" Offset="1.0" />
    </LinearGradientBrush>
    
    <!-- Glassmorphic Translucent Brushes -->
    <SolidColorBrush x:Key="CyberBgSecondaryBrush" Color="#CC0B0B0E" /> <!-- 80% opacity dark backdrop -->
    <SolidColorBrush x:Key="CyberBgElevatedBrush" Color="#EE0E0D14" />
    <SolidColorBrush x:Key="CyberBorderSubtleBrush" Color="#33FFFFFF" /> <!-- Translucent border -->
    <SolidColorBrush x:Key="CyberBorderActiveBrush" Color="{StaticResource CyberBorderActiveColor}" />
    <SolidColorBrush x:Key="CyberTextPrimaryBrush" Color="{StaticResource CyberTextPrimaryColor}" />
    <SolidColorBrush x:Key="CyberTextSecondaryBrush" Color="{StaticResource CyberTextSecondaryColor}" />
    <SolidColorBrush x:Key="CyberTextDisabledBrush" Color="{StaticResource CyberTextDisabledColor}" />
    <SolidColorBrush x:Key="CyberAccentPrimaryBrush" Color="{StaticResource CyberAccentPrimaryColor}" />
    <SolidColorBrush x:Key="CyberAccentSecondaryBrush" Color="{StaticResource CyberAccentSecondaryColor}" />
    <SolidColorBrush x:Key="CyberAccentAlertBrush" Color="{StaticResource CyberAccentAlertColor}" />
    <SolidColorBrush x:Key="CyberAccentGlowBrush" Color="{StaticResource CyberAccentGlowColor}" />
    <SolidColorBrush x:Key="CyberAccentWarningBrush" Color="{StaticResource CyberAccentWarningColor}" />

    <!-- Deprecated Resource Alias Compatibility -->
    <SolidColorBrush x:Key="WindowBackground" Color="#020204" />
    <SolidColorBrush x:Key="SidebarBackground" Color="#0B0B0E" />
    <SolidColorBrush x:Key="PrimaryText" Color="{StaticResource CyberTextPrimaryColor}" />
    <SolidColorBrush x:Key="SecondaryText" Color="{StaticResource CyberTextSecondaryColor}" />
    <SolidColorBrush x:Key="AccentColor" Color="{StaticResource CyberAccentPrimaryColor}" />
    <SolidColorBrush x:Key="BorderColor" Color="{StaticResource CyberBorderSubtleColor}" />
    <SolidColorBrush x:Key="ControlBackground" Color="#0B0B0E" />
    <SolidColorBrush x:Key="ErrorText" Color="{StaticResource CyberAccentWarningColor}" />
    <Color x:Key="AcrylicTintColor">#020204</Color>
    <system:Double x:Key="AcrylicTintOpacity">0.85</system:Double>

    <!-- ================================================================= -->
    <!-- TYPOGRAPHY                                                        -->
    <!-- ================================================================= -->
    <FontFamily x:Key="InterfaceFont">Inter, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="TechnicalFont">Consolas, Courier New, JetBrains Mono, monospace</FontFamily>

    <!-- ================================================================= -->
    <!-- TEXT STYLES                                                       -->
    <!-- ================================================================= -->
    <Style x:Key="CyberDisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="CyberTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterfaceFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
    </Style>

    <Style x:Key="CyberBodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource InterfaceFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextSecondaryBrush}" />
    </Style>

    <Style x:Key="CyberTechMonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
    </Style>

    <Style x:Key="CyberLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="ExtraBold" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextSecondaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- ================================================================= -->
    <!-- SCROLLBAR CUSTOM TEMPLATE                                         -->
    <!-- ================================================================= -->
    <Style x:Key="CyberScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{StaticResource CyberBorderSubtleBrush}" CornerRadius="0" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter Property="Background" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollViewer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" CanContentScroll="{TemplateBinding CanContentScroll}" />
                        <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" Grid.Row="0" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Width="4" AutomationProperties.Name="Vertical ScrollBar">
                            <ScrollBar.Template>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true" Orientation="Vertical">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource CyberScrollBarThumb}" Width="4" />
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </ScrollBar.Template>
                        </ScrollBar>
                        <ScrollBar x:Name="PART_HorizontalScrollBar" Grid.Column="0" Grid.Row="1" Value="{TemplateBinding HorizontalOffset}" Maximum="{TemplateBinding ScrollableWidth}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" Height="4" Orientation="Horizontal" AutomationProperties.Name="Horizontal ScrollBar">
                            <ScrollBar.Template>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" Orientation="Horizontal">
                                            <Track.Thumb>
                                                <Thumb Style="{StaticResource CyberScrollBarThumb}" Height="4" />
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </ScrollBar.Template>
                        </ScrollBar>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================= -->
    <!-- BORDER (PANELS)                                                   -->
    <!-- ================================================================= -->
    <Style x:Key="CyberPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CyberBgSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Implicit style for standard Borders -->
    <Style TargetType="Border">
        <Setter Property="CornerRadius" Value="0"/>
    </Style>

    <!-- ================================================================= -->
    <!-- BUTTON STYLE (BRUTALIST CONSOLE ACCENTED)                         -->
    <!-- ================================================================= -->
    <Style x:Key="CyberButton" TargetType="Button">
        <Setter Property="Background" Value="#0Affffff" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <!-- Top left numeric aesthetic indicator /01 style -->
                        <Rectangle x:Name="LeftAccent" Width="3" HorizontalAlignment="Left" Fill="{StaticResource CyberAccentPrimaryBrush}" VerticalAlignment="Stretch" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover: Glow effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource CyberAccentGlowBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="LeftAccent" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <!-- Pressed: Neon highlight inversion -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CyberBgPrimaryBrush}" />
                            <Setter TargetName="LeftAccent" Property="Fill" Value="{StaticResource CyberBgPrimaryBrush}"/>
                        </Trigger>
                        <!-- Disabled: Dark zinc locked -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
                            <Setter TargetName="Border" Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource CyberTextDisabledBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Implicit style for all buttons -->
    <Style TargetType="Button" BasedOn="{StaticResource CyberButton}" />

    <!-- ================================================================= -->
    <!-- TEXTBOX & PASSWORD BOX STYLE                                      -->
    <!-- ================================================================= -->
    <Style x:Key="CyberTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#440B0B0E" /> <!-- High translucency -->
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CaretBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberTextSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource CyberTextDisabledBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource CyberTextBox}" />

    <Style x:Key="CyberPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background" Value="#440B0B0E" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CaretBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberTextSecondaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource CyberTextDisabledBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox" BasedOn="{StaticResource CyberPasswordBox}" />

    <!-- ================================================================= -->
    <!-- LISTBOX STYLE                                                     -->
    <!-- ================================================================= -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="#11ffffff">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource CyberAccentGlowBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#228B5CF6" /> <!-- Semi-transparent Violet Selection -->
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ================================================================= -->
    <!-- COMBOBOX STYLE                                                    -->
    <!-- ================================================================= -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource CyberBgSecondaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Border" Grid.ColumnSpan="2" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0" />
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <ToggleButton x:Name="ToggleButton" Grid.Column="1" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent">
                                        <Path x:Name="Arrow" Fill="{StaticResource CyberTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource CyberAccentPrimaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="None">
                            <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" Background="{StaticResource CyberBgElevatedBrush}" BorderThickness="1" BorderBrush="{StaticResource CyberBorderActiveBrush}" CornerRadius="0" />
                                <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberBorderActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextPrimaryBrush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource CyberAccentGlowBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource CyberBgPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================= -->
    <!-- TAB CONTROL STYLE (BRUTALIST TABS)                                -->
    <!-- ================================================================= -->
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource CyberTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="FontFamily" Value="{StaticResource TechnicalFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <!-- Bullet dot active accent -->
                            <TextBlock Text="■ " Foreground="{StaticResource CyberAccentPrimaryBrush}" FontSize="8" VerticalAlignment="Center" Margin="0,0,6,0" x:Name="Bullet" Visibility="Collapsed"/>
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberBorderActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource CyberAccentPrimaryBrush}" />
                            <Setter TargetName="Border" Property="Background" Value="#0D00F0FF"/> <!-- Transparent Cyan Backing -->
                            <Setter TargetName="Bullet" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
    </Style>
</ResourceDictionary>
