<Page x:Class="Layla.Desktop.Views.WorkspaceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Layla.Desktop.Views"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1080"
      ShowsNavigationUI="False"
      Title="Workspace"
      Background="{DynamicResource WindowBackground}"
      Foreground="{DynamicResource PrimaryText}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" 
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding CurrentProject.Title}" FontWeight="Bold" FontSize="16" 
                           VerticalAlignment="Center" Margin="15,0" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource AccentColor}"/>

                <StackPanel Grid.Row="1" Margin="5">
                    <Button Content="← Back to Projects" Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Left" Padding="10,5"
                            Foreground="{DynamicResource SecondaryText}" Cursor="Hand"
                            Command="{Binding BackToProjectsCommand}"/>
                    <Button Content="Collaborators" Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Left" Padding="10,5"
                            Foreground="{DynamicResource AccentColor}" Cursor="Hand"
                            Command="{Binding OpenCollaboratorsModalCommand}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0">
                    <Button Content="⚙ Settings" Background="Transparent" BorderThickness="0" 
                            HorizontalAlignment="Left" Padding="0,5"
                            Foreground="{DynamicResource SecondaryText}" Cursor="Hand"
                            Command="{Binding OpenSettingsCommand}"/>
                    
                    <Button Content="🚪 Logout" Background="Transparent" BorderThickness="0" 
                            HorizontalAlignment="Left" Padding="0,5" Margin="0,5,0,0"
                            Foreground="IndianRed" Cursor="Hand"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch" 
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <Grid Grid.Column="2" Background="{DynamicResource ControlBackground}">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,0,5,0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Manuscript Editor">
                    <Frame x:Name="EditorFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Wiki">
                    <Frame x:Name="WikiFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Graph">
                    <Frame x:Name="GraphFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Voice">
                    <Frame x:Name="VoiceFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Collaborators Modal -->
        <Border Visibility="{Binding IsCollaboratorsModalVisible, Converter={StaticResource BoolToVis}}"
                Background="#CC000000" Panel.ZIndex="100" Grid.ColumnSpan="3">
            <Border Background="{DynamicResource WindowBackground}" Width="500" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Collaborators" FontSize="20" FontWeight="Bold"
                               Margin="0,0,0,15" Foreground="{DynamicResource PrimaryText}"/>

                    <!-- Invite section -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="Invite by email" FontWeight="SemiBold" Margin="0,0,0,5"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="5"
                                     Background="{DynamicResource ControlBackground}"
                                     Foreground="{DynamicResource PrimaryText}"
                                     BorderBrush="{DynamicResource BorderColor}"
                                     Text="{Binding InviteEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Invite" Margin="5,0,0,0"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    BorderThickness="0" Padding="10,5" Cursor="Hand"
                                    Command="{Binding InviteCollaboratorCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding InviteError}" Foreground="IndianRed" FontSize="12"
                                   Margin="0,5,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding InviteError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Collaborators list -->
                    <ListView Grid.Row="2" ItemsSource="{Binding Collaborators}" BorderThickness="0"
                              Background="Transparent" MaxHeight="250">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                                        Padding="5" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryText}"/>
                                            <TextBlock Text="{Binding Email}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Role}" VerticalAlignment="Center"
                                                   Margin="10,0" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                        <Button Grid.Column="2" Content="X" Background="Transparent"
                                                Foreground="IndianRed" BorderThickness="0" Padding="5,2" Cursor="Hand"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveCollaboratorCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="3" Content="Close" Background="Transparent" BorderThickness="0"
                            Foreground="Gray" Padding="15,5" Cursor="Hand" HorizontalAlignment="Right"
                            Margin="0,10,0,0" Command="{Binding CloseCollaboratorsModalCommand}"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
