<Page x:Class="Layla.Desktop.Views.PublicProjectsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      ShowsNavigationUI="False"
      Title="Public Projects"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Background="{DynamicResource CyberBgPrimaryBrush}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="PUBLIC PROJECTS" Style="{StaticResource CyberDisplayText}" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="BACK TO MY PROJECTS" Style="{StaticResource CyberButton}"
                    Padding="10,5" Cursor="Hand" Command="{Binding BackToMyProjectsCommand}"/>
        </Grid>

        <ListView Grid.Row="1" ItemsSource="{Binding PublicProjects}" BorderThickness="0" Background="Transparent"
                  x:Name="PublicProjectsList" MouseDoubleClick="PublicProjectsList_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CyberPanelBorder}" Padding="16" Margin="0,0,0,12"
                            Background="{DynamicResource CyberBgSecondaryBrush}" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource CyberTitleText}"/>
                                    <Border CornerRadius="0" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}"
                                            Visibility="{Binding IsAuthorActive, Converter={StaticResource BoolToVis}}" ToolTip="Author is active">
                                        <TextBlock Text="ACTIVE" Style="{StaticResource CyberLabel}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding LiteraryGenre}" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Synopsis}" Style="{StaticResource CyberBodyText}" TextWrapping="Wrap" MaxWidth="600" Margin="0,0,0,4"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="VIEW" Style="{StaticResource CyberButton}"
                                        Padding="10,5" Margin="0,0,6,0" Cursor="Hand"
                                        Command="{Binding DataContext.ViewProjectCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="JOIN" Style="{StaticResource CyberButton}"
                                        BorderBrush="{DynamicResource CyberAccentPrimaryBrush}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"
                                        Padding="10,5" Cursor="Hand"
                                        Command="{Binding DataContext.JoinProjectCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
