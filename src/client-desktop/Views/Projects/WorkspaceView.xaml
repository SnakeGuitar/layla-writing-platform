<Page x:Class="Layla.Desktop.Views.Projects.WorkspaceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Layla.Desktop.Views"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1080"
      ShowsNavigationUI="False"
      Title="Workspace"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource CyberBgSecondaryBrush}" 
                BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding CurrentProject.Title}" Style="{StaticResource CyberTitleText}" 
                            VerticalAlignment="Center" Margin="15,0" TextTrimming="CharacterEllipsis"
                            Foreground="{DynamicResource CyberAccentPrimaryBrush}"/>

                <StackPanel Grid.Row="1" Margin="5">
                    <Button Content="BACK TO PROJECTS" 
                            Style="{StaticResource CyberButton}"
                            HorizontalAlignment="Stretch" Padding="10,6"
                            Cursor="Hand"
                            Command="{Binding BackToProjectsCommand}"/>
                    <Button Content="COLLABORATORS" 
                            Style="{StaticResource CyberButton}"
                            HorizontalAlignment="Stretch" Padding="10,6" Margin="0,4,0,0"
                            Cursor="Hand"
                            Command="{Binding OpenCollaboratorsModalCommand}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0">
                    <Button Content="SETTINGS" 
                            Style="{StaticResource CyberButton}"
                            HorizontalAlignment="Stretch" Padding="0,5"
                            Cursor="Hand"
                            Command="{Binding OpenSettingsCommand}"/>
                    
                    <Button Content="LOGOUT" 
                            Style="{StaticResource CyberButton}"
                            BorderBrush="{DynamicResource CyberAccentWarningBrush}"
                            Foreground="{DynamicResource CyberAccentWarningBrush}"
                            HorizontalAlignment="Stretch" Padding="0,5" Margin="0,5,0,0"
                            Cursor="Hand"
                            Command="{Binding LogoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch" 
                      Background="{DynamicResource CyberBorderSubtleBrush}" Cursor="SizeWE"/>

        <Grid Grid.Column="2" Background="{DynamicResource CyberBgPrimaryBrush}">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="MANUSCRIPT EDITOR">
                    <Frame x:Name="EditorFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="WIKI">
                    <Frame x:Name="WikiFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="GRAPH">
                    <Frame x:Name="GraphFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="VOICE">
                    <Frame x:Name="VoiceFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Collaborators Modal -->
        <Border Visibility="{Binding IsCollaboratorsModalVisible, Converter={StaticResource BoolToVis}}"
                Background="#CC000000" Panel.ZIndex="100" Grid.ColumnSpan="3">
            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgElevatedBrush}" Width="500" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="COLLABORATORS" Style="{StaticResource CyberDisplayText}"
                               Margin="0,0,0,15"/>

                    <!-- Invite section -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <TextBlock Text="INVITE BY EMAIL" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" 
                                     Text="{Binding InviteEmail, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="INVITE" Margin="5,0,0,0"
                                    Style="{StaticResource CyberButton}" Padding="15,5" Cursor="Hand"
                                    Command="{Binding InviteCollaboratorCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding InviteError}" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentWarningBrush}"
                                   Margin="0,5,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding InviteError, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Collaborators list -->
                    <ListView Grid.Row="2" ItemsSource="{Binding Collaborators}" BorderThickness="0"
                              Background="Transparent" MaxHeight="250">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,0,1"
                                        Padding="5" Margin="0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CyberTitleText}" FontSize="12"/>
                                            <TextBlock Text="{Binding Email}" Style="{StaticResource CyberTechMonoText}" FontSize="10"
                                                       Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Role}" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"
                                                   Margin="10,0"/>
                                        <Button Grid.Column="2" Content="X" Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentWarningBrush}"
                                                Foreground="{DynamicResource CyberAccentWarningBrush}" Padding="6,2" Cursor="Hand"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveCollaboratorCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="3" Content="CLOSE" Style="{StaticResource CyberButton}"
                            Padding="15,5" Cursor="Hand" HorizontalAlignment="Right"
                            Margin="0,10,0,0" Command="{Binding CloseCollaboratorsModalCommand}"/>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
