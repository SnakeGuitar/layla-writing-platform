<Page x:Class="Layla.Desktop.Views.Projects.ReaderWorkspaceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1080"
      ShowsNavigationUI="False"
      Title="Reader Workspace"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource CyberBgSecondaryBrush}"
                BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding CurrentProject.Title}" Style="{StaticResource CyberTitleText}"
                           VerticalAlignment="Center" Margin="15,15" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource CyberAccentPrimaryBrush}"/>

                <!-- Author status indicator -->
                <Border Grid.Row="1" Margin="15,0,15,15" Padding="10,6" Style="{StaticResource CyberPanelBorder}"
                        Background="{DynamicResource CyberBgElevatedBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="6" Height="6" CornerRadius="0" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource CyberTextDisabledBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthorActive}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="{Binding AuthorStatusText}" Style="{StaticResource CyberTechMonoText}" FontSize="11" Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Read-only badge & details -->
                <StackPanel Grid.Row="2" Margin="15,0">
                    <Border BorderBrush="{DynamicResource CyberAccentWarningBrush}" BorderThickness="1" CornerRadius="0" Padding="8,5" Margin="0,0,0,15" Background="Transparent">
                        <TextBlock Text="READ-ONLY MODE" Style="{StaticResource CyberLabel}"
                                   Foreground="{DynamicResource CyberAccentWarningBrush}" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{Binding CurrentProject.Synopsis}" Style="{StaticResource CyberBodyText}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <TextBlock Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberTextSecondaryBrush}" Margin="0,0,0,15">
                        <Run Text="GENRE: "/><Run Text="{Binding CurrentProject.LiteraryGenre}"/>
                    </TextBlock>

                    <Button Content="BACK TO PUBLIC" Style="{StaticResource CyberButton}"
                            HorizontalAlignment="Stretch" Padding="10,6" Cursor="Hand"
                            Command="{Binding BackToPublicProjectsCommand}"/>
                </StackPanel>

                <Button Grid.Row="3" Content="LOGOUT" Style="{StaticResource CyberButton}"
                        BorderBrush="{DynamicResource CyberAccentWarningBrush}"
                        Foreground="{DynamicResource CyberAccentWarningBrush}"
                        HorizontalAlignment="Stretch" Padding="15,10" Margin="15,15" Cursor="Hand"
                        Command="{Binding LogoutCommand}"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource CyberBorderSubtleBrush}" Cursor="SizeWE"/>

        <!-- Main content area with tabs -->
        <Grid Grid.Column="2" Background="{DynamicResource CyberBgPrimaryBrush}">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabItem Header="MANUSCRIPT">
                    <Frame x:Name="EditorFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="WIKI">
                    <Frame x:Name="WikiFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="GRAPH">
                    <Frame x:Name="GraphFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="VOICE">
                    <Frame x:Name="VoiceFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Page>
