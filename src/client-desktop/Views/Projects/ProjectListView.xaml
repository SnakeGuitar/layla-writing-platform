<Page x:Class="Layla.Desktop.Views.Projects.ProjectListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Layla.Desktop.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      ShowsNavigationUI="False"
      Title="ProjectListView"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">
    
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Background="{DynamicResource CyberBgPrimaryBrush}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="MY PROJECTS" Style="{StaticResource CyberDisplayText}" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="BROWSE PUBLIC" Style="{StaticResource CyberButton}"
                            Padding="10,5" Cursor="Hand" Click="BrowsePublicButton_Click"/>
                    <Button Content="CREATE PROJECT" Style="{StaticResource CyberButton}"
                            Padding="10,5" Cursor="Hand" Command="{Binding OpenCreateModalCommand}" Margin="6,0,0,0"/>
                    <Button Content="SETTINGS" Style="{StaticResource CyberButton}"
                            Padding="10,5" Cursor="Hand" Click="SettingsButton_Click" Margin="6,0,0,0"/>
                    <Button Content="LOGOUT" Style="{StaticResource CyberButton}"
                            BorderBrush="{DynamicResource CyberAccentWarningBrush}" Foreground="{DynamicResource CyberAccentWarningBrush}"
                            Padding="10,5" Cursor="Hand" Click="LogoutButton_Click" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
            
            <ListView x:Name="ProjectsListView" Grid.Row="1" ItemsSource="{Binding Projects}" BorderThickness="0" Background="Transparent" MouseDoubleClick="ProjectsListView_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CyberPanelBorder}" Padding="16" Margin="0,0,0,12" Background="{DynamicResource CyberBgSecondaryBrush}" Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource CyberTitleText}"/>
                                        
                                        <Border CornerRadius="0" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" BorderThickness="1" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}">
                                            <TextBlock Text="PUBLIC" Style="{StaticResource CyberLabel}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"/>
                                        </Border>
                                        
                                        <Border CornerRadius="0" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource CyberBgSecondaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource CyberBorderActiveBrush}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UserRole}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserRole}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserRole}" Value="OWNER">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserRole}" Value="EDITOR">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource CyberTextPrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UserRole}" Value="READER">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource CyberTextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding UserRole}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CyberLabel}">
                                                        <Setter Property="Foreground" Value="{DynamicResource CyberTextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UserRole}" Value="OWNER">
                                                                <Setter Property="Foreground" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UserRole}" Value="EDITOR">
                                                                <Setter Property="Foreground" Value="{DynamicResource CyberTextPrimaryBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UserRole}" Value="READER">
                                                                <Setter Property="Foreground" Value="{DynamicResource CyberTextSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding LiteraryGenre}" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberTextSecondaryBrush}" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding Synopsis}" Style="{StaticResource CyberBodyText}" TextWrapping="Wrap" MaxWidth="600" Margin="0,0,0,4"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="EDIT" Style="{StaticResource CyberButton}" Padding="8,4" Cursor="Hand" 
                                            Command="{Binding DataContext.OpenEditModalCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"/>
                                    <Button Content="DELETE" Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentWarningBrush}" Foreground="{DynamicResource CyberAccentWarningBrush}" Padding="8,4" Cursor="Hand" 
                                            Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Create Project Modal -->
        <Border x:Name="CreateProjectModal" Visibility="{Binding IsCreateModalVisible, Converter={StaticResource BoolToVis}}" Background="#CC000000" Panel.ZIndex="100">
            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgElevatedBrush}" Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="CREATE NEW PROJECT" Style="{StaticResource CyberDisplayText}" FontSize="18" Margin="0,0,0,10"/>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="TITLE" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NewProjectTitle" Text="{Binding NewProjectTitle, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="GENRE" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NewProjectGenre" Text="{Binding NewProjectGenre, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="SYNOPSIS" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="NewProjectSynopsis" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding NewProjectSynopsis, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Content="Public project" IsChecked="{Binding NewProjectIsPublic}" Foreground="{DynamicResource CyberTextPrimaryBrush}" Margin="0,4,0,10"/>

                    <TextBlock x:Name="CreateProjectError" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentWarningBrush}" Visibility="{Binding CreateError, Converter={StaticResource BoolToVis}}" TextWrapping="Wrap"
                               Text="{Binding CreateError}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Style="{StaticResource CyberButton}" Padding="15,5" Cursor="Hand" Command="{Binding CloseCreateModalCommand}"/>
                        <Button x:Name="SaveProjectButton" Content="CREATE" Style="{StaticResource CyberButton}" Padding="15,5" Cursor="Hand" Command="{Binding CreateProjectCommand}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Edit Project Modal -->
        <Border x:Name="EditProjectModal" Visibility="{Binding IsEditModalVisible, Converter={StaticResource BoolToVis}}" Background="#CC000000" Panel.ZIndex="100">
            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgElevatedBrush}" Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="EDIT PROJECT" Style="{StaticResource CyberDisplayText}" FontSize="18" Margin="0,0,0,10"/>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="TITLE" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="EditProjectTitle" Text="{Binding EditProjectTitle, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="GENRE" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="EditProjectGenre" Text="{Binding EditProjectGenre, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="SYNOPSIS" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                        <TextBox x:Name="EditProjectSynopsis" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                 Text="{Binding EditProjectSynopsis, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <CheckBox Content="Public project" IsChecked="{Binding EditProjectIsPublic}" Foreground="{DynamicResource CyberTextPrimaryBrush}" Margin="0,4,0,10"/>

                    <TextBlock x:Name="EditProjectError" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentWarningBrush}" Visibility="{Binding EditError, Converter={StaticResource BoolToVis}}" TextWrapping="Wrap"
                               Text="{Binding EditError}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Style="{StaticResource CyberButton}" Padding="15,5" Cursor="Hand" Command="{Binding CloseEditModalCommand}"/>
                        <Button x:Name="UpdateProjectButton" Content="SAVE" Style="{StaticResource CyberButton}" Padding="15,5" Cursor="Hand" Command="{Binding UpdateProjectCommand}" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
