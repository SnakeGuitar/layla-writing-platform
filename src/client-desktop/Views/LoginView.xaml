<Page x:Class="Layla.Desktop.Views.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ShowsNavigationUI="False"
      Title="Sign In"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Border Width="360" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Style="{StaticResource CyberPanelBorder}">
            <StackPanel Margin="40">
                <TextBlock Text="LAYLA" Style="{StaticResource CyberDisplayText}" 
                           HorizontalAlignment="Center" Foreground="{StaticResource CyberAccentPrimaryBrush}" Margin="0,0,0,10"/>
                <TextBlock Text="Sign in to your workspace" Style="{StaticResource CyberBodyText}" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="EMAIL" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,15"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource CyberPasswordBox}" Margin="0,0,0,25"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource CyberAccentWarningBrush}" Style="{StaticResource CyberTechMonoText}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" 
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           Text="{Binding ErrorMessage}"/>

                <Button x:Name="LoginButton" Content="{Binding LoginButtonContent}" Height="40"
                        Cursor="Hand" Command="{Binding SignInCommand}"
                        Style="{StaticResource CyberButton}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="No account? " Style="{StaticResource CyberBodyText}"/>
                    <TextBlock Text="Create one" Style="{StaticResource CyberTechMonoText}" Foreground="{StaticResource CyberAccentPrimaryBrush}" 
                               Cursor="Hand" MouseLeftButtonDown="NavigateToSignUp_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>