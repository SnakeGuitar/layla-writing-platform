<Page x:Class="Layla.Desktop.Views.WikiEntityEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="WikiEntityEditorView" Background="{DynamicResource WindowBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Entity list -->
            <ColumnDefinition Width="250" MinWidth="180" MaxWidth="380"/>
            <ColumnDefinition Width="2"/>
            <!-- Editor form -->
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <!-- Appearances (narrative arc) -->
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Entity List ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WIKI ENTRIES" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryText}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+ New" Padding="6,3"
                                Background="Transparent" Foreground="{DynamicResource AccentColor}"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                Command="{Binding NewEntryCommand}"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Entries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="Transparent" BorderThickness="0" Padding="5,5"
                         SelectionChanged="EntryListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Character">
                                                    <Setter Property="Background" Value="#4FC3F7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Location">
                                                    <Setter Property="Background" Value="#81C784"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Event">
                                                    <Setter Property="Background" Value="#FFB74D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Object">
                                                    <Setter Property="Background" Value="#CE93D8"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding EntityType}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="6,5"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <!-- ═══ CENTER: Editor Form ═══ -->
        <Grid Grid.Column="2" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Wiki Entry" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}"/>

            <!-- Name -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" VerticalAlignment="Center"
                       FontWeight="Medium" Foreground="{DynamicResource SecondaryText}"/>
            <TextBox Grid.Row="2" Grid.Column="1" Height="30" Padding="5"
                     Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Type -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Type:" VerticalAlignment="Center"
                       FontWeight="Medium" Foreground="{DynamicResource SecondaryText}"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Height="30" Padding="5,4"
                      ItemsSource="{Binding EntityTypes}"
                      SelectedItem="{Binding EntityType}"
                      Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                      BorderBrush="{DynamicResource BorderColor}"/>

            <!-- Tags -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Tags:" VerticalAlignment="Center"
                       FontWeight="Medium" Foreground="{DynamicResource SecondaryText}"/>
            <TextBox Grid.Row="6" Grid.Column="1" Height="30" Padding="5"
                     Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     ToolTip="Separate with commas"
                     Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Description -->
            <TextBlock Grid.Row="8" Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,5,0,0"
                       FontWeight="Medium" Foreground="{DynamicResource SecondaryText}"/>
            <TextBox Grid.Row="8" Grid.Column="1" Padding="5"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Background="{DynamicResource ControlBackground}" Foreground="{DynamicResource PrimaryText}"
                     BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Delete" Width="90" Height="35" Margin="0,0,10,0"
                        Background="Transparent" Foreground="IndianRed"
                        BorderBrush="IndianRed" BorderThickness="1" Cursor="Hand"
                        Command="{Binding DeleteCommand}"/>
                <Button Content="Save" Width="100" Height="35"
                        Background="{DynamicResource AccentColor}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="3" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <!-- ═══ RIGHT: Narrative Arc (Appearances) ═══ -->
        <Border Grid.Column="4" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <TextBlock Text="NARRATIVE ARC" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryText}"/>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Appearances}"
                         Background="Transparent" BorderThickness="0" Padding="5,5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                    Background="{DynamicResource ControlBackground}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ChapterTitle}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ManuscriptTitle}" FontSize="10"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty state -->
                <TextBlock Grid.Row="1" FontSize="11" Foreground="{DynamicResource SecondaryText}"
                           TextWrapping="Wrap" Padding="12,20" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Top"
                           Text="Select an entity to see which chapters it appears in.">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Appearances.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Page>
