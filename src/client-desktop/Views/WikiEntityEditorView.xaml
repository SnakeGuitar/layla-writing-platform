<Page x:Class="Layla.Desktop.Views.WikiEntityEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="WikiEntityEditorView"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Entity list -->
            <ColumnDefinition Width="250" MinWidth="180" MaxWidth="380"/>
            <ColumnDefinition Width="2"/>
            <!-- Editor form -->
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <!-- Appearances (narrative arc) -->
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Entity List ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource CyberBgSecondaryBrush}"
                BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="12,10" BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WIKI ENTRIES" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                        <Button x:Name="NewButton" Grid.Column="1" Content="NEW" Style="{StaticResource CyberButton}" Padding="8,4" Cursor="Hand"
                                Command="{Binding NewEntryCommand}"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Entries}"
                          SelectedItem="{Binding SelectedEntry}"
                          Background="Transparent" BorderThickness="0" Padding="5,5"
                          SelectionChanged="EntryListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="6" Height="6" CornerRadius="0" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CyberTextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Character">
                                                    <Setter Property="Background" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Location">
                                                    <Setter Property="Background" Value="{DynamicResource CyberTextPrimaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Event">
                                                    <Setter Property="Background" Value="{DynamicResource CyberAccentWarningBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Object">
                                                    <Setter Property="Background" Value="{DynamicResource CyberTextSecondaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EntityType}" Value="Concept">
                                                    <Setter Property="Background" Value="{DynamicResource CyberTextDisabledBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CyberTitleText}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding EntityType}" Style="{StaticResource CyberTechMonoText}" FontSize="10" Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="6,5"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource CyberBorderSubtleBrush}" Cursor="SizeWE"/>

        <!-- ═══ CENTER: Editor Form ═══ -->
        <Grid Grid.Column="2" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="WIKI ENTRY" Style="{StaticResource CyberDisplayText}" FontSize="18"/>

            <!-- Name -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="NAME:" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
            <TextBox x:Name="NameTextBox" Grid.Row="2" Grid.Column="1" Height="30"
                      Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Type -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="TYPE:" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
            <ComboBox x:Name="TypeComboBox" Grid.Row="4" Grid.Column="1" Height="30"
                      ItemsSource="{Binding EntityTypes}"
                      SelectedItem="{Binding EntityType}"/>

            <!-- Tags -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="TAGS:" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
            <TextBox x:Name="TagsTextBox" Grid.Row="6" Grid.Column="1" Height="30"
                      ToolTip="Separate with commas"
                      Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Description -->
            <TextBlock Grid.Row="8" Grid.Column="0" Text="DESCRIPTION:" Style="{StaticResource CyberLabel}" VerticalAlignment="Top" Margin="0,5,0,0"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Row="8" Grid.Column="1"
                      TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                      Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Buttons + status -->
            <Grid Grid.Row="12" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentPrimaryBrush}" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,12,0" TextWrapping="Wrap"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="VIEW GRAPH" Width="110" Height="30" Margin="0,0,10,0"
                            Style="{StaticResource CyberButton}" Command="{Binding ViewInGraphCommand}"/>
                    
                    <Button x:Name="DeleteButton" Content="DELETE" Width="90" Height="30" Margin="0,0,10,0"
                            Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentWarningBrush}" Foreground="{DynamicResource CyberAccentWarningBrush}"
                            Command="{Binding DeleteCommand}"/>
                    
                    <Button x:Name="SaveButton" Content="SAVE" Width="100" Height="30"
                            Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <GridSplitter Grid.Column="3" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource CyberBorderSubtleBrush}" Cursor="SizeWE"/>

        <!-- ═══ RIGHT: Narrative Arc (Appearances) ═══ -->
        <Border Grid.Column="4" Background="{DynamicResource CyberBgSecondaryBrush}"
                BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="12,10" BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="NARRATIVE ARC" Style="{StaticResource CyberLabel}"/>
                </Border>

                <ListBox Grid.Row="1" ItemsSource="{Binding Appearances}"
                          Background="Transparent" BorderThickness="0" Padding="5,5"
                          SelectionChanged="AppearanceListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgSecondaryBrush}"
                                    Padding="6,5" Margin="0,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding ChapterTitle}" Style="{StaticResource CyberTitleText}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ManuscriptTitle}" Style="{StaticResource CyberTechMonoText}" FontSize="10" Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Empty state -->
                <TextBlock Grid.Row="1" Text="Select an entity to see which chapters it appears in."
                           TextWrapping="Wrap" Padding="12,20" TextAlignment="Center"
                           HorizontalAlignment="Center" VerticalAlignment="Top">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CyberBodyText}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Appearances.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Page>
