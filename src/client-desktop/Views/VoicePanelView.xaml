<Page x:Class="Layla.Desktop.Views.VoicePanelView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Voice Room"
      Background="{DynamicResource WindowBackground}"
      Foreground="{DynamicResource PrimaryText}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Connection status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Ellipse Width="12" Height="12" Fill="{Binding StatusIndicatorFill}"
                     VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusText}" FontSize="14"
                       VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
            <Button Content="{Binding ConnectButtonContent}" Margin="15,0,0,0"
                    Padding="12,6" Background="{DynamicResource AccentColor}"
                    Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding ConnectCommand}"
                    Visibility="{Binding IsConnectVisible, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Leave Room" Margin="10,0,0,0"
                    Padding="12,6" Background="IndianRed"
                    Foreground="White" BorderThickness="0" Cursor="Hand"
                    Command="{Binding LeaveCommand}"
                    Visibility="{Binding IsLeaveVisible, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Online Now (Presence) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10" 
                        Visibility="{Binding IsOnlineParticipantsVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Online Now" FontSize="12" FontWeight="Bold" 
                           Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding OnlineParticipants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ControlBackground}" 
                                    CornerRadius="4" Padding="6,3" Margin="0,0,5,5"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="LimeGreen" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" Foreground="{DynamicResource PrimaryText}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Participant list (Voice) -->
            <Border Grid.Row="1" Background="{DynamicResource ControlBackground}"
                    CornerRadius="8" Padding="10" Margin="0,0,0,15"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <TextBlock Visibility="{Binding IsEmptyRoomVisible, Converter={StaticResource BoolToVis}}" Text="No participants in voice room"
                               Foreground="{DynamicResource SecondaryText}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ListBox x:Name="ParticipantList" Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding Participants}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,4">
                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                        <Setter Property="Fill" Value="LimeGreen"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="14"
                                               VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="{Binding RoleLabel}" FontSize="11"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- PTT Button -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
            <Button x:Name="PttButton" Width="160" Height="160"
                    IsEnabled="{Binding IsPttEnabled}" Cursor="Hand"
                    PreviewMouseDown="PttButton_MouseDown"
                    PreviewMouseUp="PttButton_MouseUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PttBorder" CornerRadius="80"
                                Background="#3D5AFE" BorderThickness="3" BorderBrush="#1A237E">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="PTT" FontSize="24" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PttHint" Text="Hold to talk" FontSize="11"
                                           Foreground="#B0BEC5" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PttBorder" Property="Background" Value="#F44336"/>
                                <Setter TargetName="PttBorder" Property="BorderBrush" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PttBorder" Property="Background" Value="#455A64"/>
                                <Setter TargetName="PttBorder" Property="BorderBrush" Value="#37474F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="{Binding PttStatusText}" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       Foreground="{DynamicResource SecondaryText}"/>
        </StackPanel>
    </Grid>
</Page>
