<Page x:Class="Layla.Desktop.Views.VoicePanelView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Voice Room"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Connection status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <Border Width="8" Height="8" CornerRadius="0" Background="{Binding StatusIndicatorFill}"
                    VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource CyberTechMonoText}"
                       VerticalAlignment="Center" Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
            
            <Button Content="{Binding ConnectButtonContent}" Margin="15,0,0,0" Style="{StaticResource CyberButton}"
                    Padding="12,6" Cursor="Hand" Command="{Binding ConnectCommand}"
                    Visibility="{Binding IsConnectVisible, Converter={StaticResource BoolToVis}}"/>
            
            <Button Content="LEAVE ROOM" Margin="10,0,0,0" Style="{StaticResource CyberButton}"
                    BorderBrush="{DynamicResource CyberAccentWarningBrush}" Foreground="{DynamicResource CyberAccentWarningBrush}"
                    Padding="12,6" Cursor="Hand" Command="{Binding LeaveCommand}"
                    Visibility="{Binding IsLeaveVisible, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Online Now (Presence) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10" 
                        Visibility="{Binding IsOnlineParticipantsVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="ONLINE PARTICIPANTS" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding OnlineParticipants}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgSecondaryBrush}"
                                    Padding="6,3" Margin="0,0,6,6">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberAccentPrimaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CyberTechMonoText}" FontSize="11" Foreground="{DynamicResource CyberTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Participant list (Voice) -->
            <Border Grid.Row="1" Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgSecondaryBrush}"
                    Padding="10" Margin="0,0,0,15">
                <Grid>
                    <TextBlock Visibility="{Binding IsEmptyRoomVisible, Converter={StaticResource BoolToVis}}" Text="NO PARTICIPANTS IN VOICE ROOM" Style="{StaticResource CyberTechMonoText}"
                               Foreground="{DynamicResource CyberTextSecondaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <ListBox x:Name="ParticipantList" Background="Transparent" BorderThickness="0"
                             ItemsSource="{Binding Participants}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,4">
                                    <Border Width="6" Height="6" CornerRadius="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CyberTextDisabledBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSpeaking}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource CyberTitleText}" FontSize="12"
                                               VerticalAlignment="Center" Foreground="{DynamicResource CyberTextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding RoleLabel}" Style="{StaticResource CyberTechMonoText}" FontSize="10"
                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- PTT Button -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
            <Button x:Name="PttButton" Width="160" Height="160" Margin="0,10,0,0"
                    IsEnabled="{Binding IsPttEnabled}" Cursor="Hand"
                    PreviewMouseDown="PttButton_MouseDown"
                    PreviewMouseUp="PttButton_MouseUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PttBorder" CornerRadius="0" BorderThickness="1"
                                Background="{DynamicResource CyberBgElevatedBrush}" 
                                BorderBrush="{DynamicResource CyberBorderActiveBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock x:Name="PttText" Text="PTT" Style="{StaticResource CyberDisplayText}" FontSize="24"
                                           Foreground="{DynamicResource CyberTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="PttHint" Text="HOLD TO TALK" Style="{StaticResource CyberTechMonoText}" FontSize="9"
                                           Foreground="{DynamicResource CyberTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PttBorder" Property="Background" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                <Setter TargetName="PttBorder" Property="BorderBrush" Value="{DynamicResource CyberAccentPrimaryBrush}"/>
                                <Setter TargetName="PttText" Property="Foreground" Value="{DynamicResource CyberBgPrimaryBrush}"/>
                                <Setter TargetName="PttHint" Property="Foreground" Value="{DynamicResource CyberBgPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PttBorder" Property="Background" Value="{DynamicResource CyberBgPrimaryBrush}"/>
                                <Setter TargetName="PttBorder" Property="BorderBrush" Value="{DynamicResource CyberBorderSubtleBrush}"/>
                                <Setter TargetName="PttText" Property="Foreground" Value="{DynamicResource CyberTextDisabledBrush}"/>
                                <Setter TargetName="PttHint" Property="Foreground" Value="{DynamicResource CyberTextDisabledBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <TextBlock Text="{Binding PttStatusText}" Style="{StaticResource CyberTechMonoText}" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,12,0,0"
                       Foreground="{DynamicResource CyberTextSecondaryBrush}"/>
        </StackPanel>
    </Grid>
</Page>
