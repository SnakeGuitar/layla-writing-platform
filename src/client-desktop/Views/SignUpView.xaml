<Page x:Class="Layla.Desktop.Views.SignUpView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      ShowsNavigationUI="False"
      Title="Sign Up"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Border Width="360" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Style="{StaticResource CyberPanelBorder}">
            <StackPanel Margin="40">
                <TextBlock Text="LAYLA" Style="{StaticResource CyberDisplayText}" 
                           HorizontalAlignment="Center" Foreground="{StaticResource CyberAccentPrimaryBrush}" Margin="0,0,0,10"/>
                <TextBlock Text="Create your author account" Style="{StaticResource CyberBodyText}" 
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <StackPanel Visibility="{Binding IsSignUpStep, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="EMAIL" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,15"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="DISPLAY NAME" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                    <TextBox x:Name="DisplayNameTextBox" Style="{StaticResource CyberTextBox}" Margin="0,0,0,15"
                             Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="PASSWORD" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource CyberPasswordBox}" Margin="0,0,0,25"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </StackPanel>

                <StackPanel Visibility="{Binding IsVerificationStep, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="VERIFICATION PIN" Style="{StaticResource CyberLabel}" Margin="0,0,0,5"/>
                    <TextBox x:Name="PinTextBox" Style="{StaticResource CyberTextBox}" MaxLength="6" Margin="0,0,0,25"
                             Text="{Binding VerificationPin, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <TextBlock x:Name="StatusText" TextWrapping="Wrap" Style="{StaticResource CyberTechMonoText}"
                           HorizontalAlignment="Center" Margin="0,0,0,10" TextAlignment="Center"
                           Foreground="{DynamicResource CyberAccentWarningBrush}"
                           Text="{Binding StatusMessage}"/>

                <Button x:Name="SignUpButton" Content="{Binding SignUpButtonContent}" Height="40"
                        Cursor="Hand" Command="{Binding SignUpCommand}"
                        Visibility="{Binding IsSignUpStep, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CyberButton}"/>

                <Button x:Name="VerifyButton" Content="{Binding VerifyButtonContent}" Height="40"
                        Cursor="Hand" Command="{Binding VerifyCommand}"
                        Visibility="{Binding IsVerificationStep, Converter={StaticResource BoolToVis}}"
                        Style="{StaticResource CyberButton}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Already have an account? " Style="{StaticResource CyberBodyText}"/>
                    <TextBlock Text="Sign in" Style="{StaticResource CyberTechMonoText}" Foreground="{StaticResource CyberAccentPrimaryBrush}" 
                               Cursor="Hand" MouseLeftButtonDown="NavigateToLogin_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>