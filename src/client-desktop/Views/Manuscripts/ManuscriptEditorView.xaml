<Page x:Class="Layla.Desktop.Views.Manuscripts.ManuscriptEditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="1100"
      Title="ManuscriptEditorView">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.ColumnDefinitions>
            <!-- Chapter navigation sidebar -->
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="350"/>
            <ColumnDefinition Width="2"/>
            <!-- Editor area -->
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2"/>
            <!-- Context panel (wiki entities in current chapter) -->
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT SIDEBAR: Manuscripts + Chapters ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Manuscript selector -->
                <Border Grid.Row="0" Padding="10,10,10,5" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="MANUSCRIPTS" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ManuscriptComboBox"
                                      Grid.Column="0"
                                      ItemsSource="{Binding Manuscripts}"
                                      SelectedItem="{Binding SelectedManuscript}"
                                      DisplayMemberPath="Title"
                                      Background="{DynamicResource ControlBackground}"
                                      Foreground="{DynamicResource PrimaryText}"
                                      BorderBrush="{DynamicResource BorderColor}"
                                      Padding="5,4" FontSize="12"
                                      SelectionChanged="ManuscriptComboBox_SelectionChanged"/>
                            <Button x:Name="AddManuscriptButton" Grid.Column="1" Content="+" ToolTip="Add manuscript"
                                    Width="26" Height="26" Margin="4,0,0,0"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                    Click="AddManuscriptButton_Click"/>
                            <Button Grid.Column="2" x:Name="DeleteManuscriptButton"
                                    ToolTip="Delete the current manuscript and all its chapters"
                                    Width="26" Height="26" Margin="4,0,0,0"
                                    Background="IndianRed" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                    Content="🗑"
                                    Click="DeleteManuscriptButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Chapter list header -->
                <Border Grid.Row="1" Padding="10,8,10,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CHAPTERS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                        <Button x:Name="AddChapterButton" Grid.Column="1" Content="+ Add" ToolTip="Add chapter"
                                Background="Transparent" Foreground="{DynamicResource AccentColor}"
                                BorderThickness="0" FontSize="11" Cursor="Hand" Padding="4,2"
                                Click="AddChapterButton_Click"/>
                    </Grid>
                </Border>

                <!-- Chapter list -->
                <ListBox Grid.Row="2" x:Name="ChapterListBox"
                         ItemsSource="{Binding CurrentChapters}"
                         SelectedItem="{Binding SelectedChapterItem}"
                         Background="Transparent" BorderThickness="0"
                         Padding="5,0"
                         SelectionChanged="ChapterListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="12"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                           Padding="6,5"/>
                                <Button Grid.Column="1" Content="🗑" FontSize="11"
                                        Background="Transparent" Foreground="IndianRed"
                                        BorderThickness="0" Cursor="Hand" Padding="6,2"
                                        VerticalAlignment="Center" ToolTip="Delete chapter"
                                        Tag="{Binding}"
                                        Visibility="{Binding IsEditablePage, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVis}}"
                                        Click="DeleteChapterButton_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <!-- ═══ RIGHT: Editor ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Padding="15,8" Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Manuscript Editor" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="SaveButton" Content="💾 Save"
                            ToolTip="Save the current chapter now (Ctrl+S)"
                            Background="{DynamicResource AccentColor}" Foreground="White"
                            BorderThickness="0" Padding="10,4" FontWeight="SemiBold"
                            Cursor="Hand" Click="SaveButton_Click"/>
                </Grid>
            </Border>

            <!-- ═══ TOOLBAR ═══ -->
            <ToolBarTray Grid.Row="1" Margin="10,8,10,0" Background="{DynamicResource ControlBackground}">
                <!-- Row 1: Font family, size, colors -->
                <ToolBar Background="Transparent" Band="0" BandIndex="0">
                    <ComboBox x:Name="FontFamilyComboBox" Width="140" FontSize="12"
                              Background="{DynamicResource ControlBackground}"
                              Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource BorderColor}"
                              ToolTip="Font Family"
                              SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                    <ComboBox x:Name="FontSizeComboBox" Width="55" FontSize="12" IsEditable="True"
                              Background="{DynamicResource ControlBackground}"
                              Foreground="{DynamicResource PrimaryText}"
                              BorderBrush="{DynamicResource BorderColor}"
                              ToolTip="Font Size"
                              SelectionChanged="FontSizeComboBox_SelectionChanged"
                              KeyDown="FontSizeComboBox_KeyDown"/>
                    <Separator/>
                    <Button x:Name="FontColorButton" ToolTip="Font Color" Click="FontColorButton_Click"
                            Padding="4,2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="A" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                            <Border x:Name="FontColorIndicator" Height="3" Width="16" Background="Black" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="HighlightColorButton" ToolTip="Highlight Color" Click="HighlightColorButton_Click"
                            Padding="4,2" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="ab" FontSize="12" HorizontalAlignment="Center">
                                <TextBlock.Background>
                                    <SolidColorBrush x:Name="HighlightPreviewBrush" Color="Yellow"/>
                                </TextBlock.Background>
                            </TextBlock>
                            <Border x:Name="HighlightColorIndicator" Height="3" Width="16" Background="Yellow" Margin="0,1,0,0"/>
                        </StackPanel>
                    </Button>
                </ToolBar>

                <!-- Row 2: Formatting, alignment, lists, images -->
                <ToolBar Background="Transparent" Band="1" BandIndex="0">
                    <Button Command="ApplicationCommands.Undo" Content="Undo" ToolTip="Undo (Ctrl+Z)"/>
                    <Button Command="ApplicationCommands.Redo" Content="Redo" ToolTip="Redo (Ctrl+Y)"/>
                    <Separator/>
                    <Button Command="ApplicationCommands.Cut" Content="Cut"/>
                    <Button Command="ApplicationCommands.Copy" Content="Copy"/>
                    <Button Command="ApplicationCommands.Paste" Content="Paste"/>
                    <Separator/>
                    <Button Command="EditingCommands.ToggleBold" ToolTip="Bold (Ctrl+B)">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                    </Button>
                    <Button Command="EditingCommands.ToggleItalic" ToolTip="Italic (Ctrl+I)">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                    </Button>
                    <Button Command="EditingCommands.ToggleUnderline" ToolTip="Underline (Ctrl+U)">
                        <TextBlock Text="U" TextDecorations="Underline" FontSize="13"/>
                    </Button>
                    <Button x:Name="StrikethroughButton" ToolTip="Strikethrough" Click="StrikethroughButton_Click">
                        <TextBlock Text="S" TextDecorations="Strikethrough" FontSize="13"/>
                    </Button>
                    <Separator/>
                    <Button Command="EditingCommands.AlignLeft" Content="Left" ToolTip="Align Left"/>
                    <Button Command="EditingCommands.AlignCenter" Content="Center" ToolTip="Align Center"/>
                    <Button Command="EditingCommands.AlignRight" Content="Right" ToolTip="Align Right"/>
                    <Button Command="EditingCommands.AlignJustify" Content="Justify" ToolTip="Justify"/>
                    <Separator/>
                    <Button Command="EditingCommands.ToggleBullets" Content="Bullets" ToolTip="Bulleted List"/>
                    <Button Command="EditingCommands.ToggleNumbering" Content="Numbering" ToolTip="Numbered List"/>
                    <Separator/>
                    <Button Command="EditingCommands.DecreaseIndentation" Content="Outdent"/>
                    <Button Command="EditingCommands.IncreaseIndentation" Content="Indent"/>
                    <Separator/>
                    <Button x:Name="InsertImageButton" Content="Image" ToolTip="Insert Image" Click="InsertImageButton_Click"/>
                </ToolBar>
            </ToolBarTray>

            <!-- Editor -->
            <Border Grid.Row="2" Margin="10,8,10,0" Background="{DynamicResource ControlBackground}" CornerRadius="6" Padding="8">
                <RichTextBox x:Name="EditorRichTextBox"
                             Background="Transparent"
                             Foreground="{DynamicResource PrimaryText}"
                             BorderThickness="0"
                             FontSize="14"
                             FontFamily="Segoe UI"
                             Padding="10"
                             VerticalAlignment="Top"
                             TextChanged="EditorRichTextBox_TextChanged"
                             SelectionChanged="EditorRichTextBox_SelectionChanged"
                             PreviewMouseLeftButtonUp="EditorRichTextBox_PreviewMouseLeftButtonUp"
                             AcceptsReturn="True"
                             IsDocumentEnabled="True">
                    <FlowDocument>
                        <Paragraph>
                            <Run Text="Start writing your amazing story here..."/>
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </Border>

            <!-- Footer: word count + save status -->
            <Border Grid.Row="3" Padding="15,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding IsSaving, Converter={StaticResource BoolToVis}, FallbackValue=''}"
                               Foreground="{DynamicResource SecondaryText}" FontSize="11"
                               Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value=""/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                        <Setter Property="Text" Value="Saving..."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource AccentColor}" FontSize="11"
                               HorizontalAlignment="Left" Margin="12,0,0,0"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                    <Border Grid.Column="2" Padding="6,2" Margin="0,0,12,0" CornerRadius="3"
                            Background="#7A4A1A" VerticalAlignment="Center"
                            Visibility="{Binding HasUnsavedOfflineChanges, Converter={StaticResource BoolToVis}}"
                            ToolTip="Last save did not reach the worldbuilding service. Press Ctrl+S to retry.">
                        <TextBlock Text="⚠ OFFLINE" FontSize="10" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock Grid.Column="3" HorizontalAlignment="Right"
                               Foreground="{DynamicResource SecondaryText}"
                               FontSize="12" FontFamily="Segoe UI"
                               Text="{Binding WordCountText}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ RIGHT SPLITTER ═══ -->
        <GridSplitter Grid.Column="3" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <!-- ═══ RIGHT SIDEBAR: Context Panel + Version History ═══ -->
        <Border Grid.Column="4" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
            <TabControl Background="Transparent" BorderThickness="0" Margin="2">
                <!-- ═══ TAB 1: CONTEXT (Wiki Mentions) ═══ -->
                <TabItem Header="Context" FontSize="11" FontWeight="SemiBold" Cursor="Hand" Padding="12,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Mentions list -->
                        <ListBox Grid.Row="0" x:Name="MentionsListBox"
                                 ItemsSource="{Binding CurrentMentions}"
                                 Background="Transparent" BorderThickness="0" Padding="5,5"
                                 SelectionChanged="MentionsListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6,5" Margin="0,1" CornerRadius="4"
                                            Background="{DynamicResource ControlBackground}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EntityType}" Value="Character">
                                                                <Setter Property="Background" Value="#4FC3F7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EntityType}" Value="Location">
                                                                <Setter Property="Background" Value="#81C784"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EntityType}" Value="Event">
                                                                <Setter Property="Background" Value="#FFB74D"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EntityType}" Value="Object">
                                                                <Setter Property="Background" Value="#CE93D8"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EntityType}" Value="Concept">
                                                                <Setter Property="Background" Value="#90A4AE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding EntityType}" FontSize="10"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="0" Text="No entities detected in this chapter yet.&#x0a;&#x0a;Create wiki entries and their names will be automatically linked when you write."
                                   FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                   TextWrapping="Wrap" Padding="12,20"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   TextAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentMentions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Legend -->
                        <Border Grid.Row="1" Padding="10,8" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                            <WrapPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#4FC3F7" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Character" FontSize="9" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#81C784" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Location" FontSize="9" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#FFB74D" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Event" FontSize="9" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#CE93D8" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Object" FontSize="9" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#90A4AE" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Concept" FontSize="9" Foreground="{DynamicResource SecondaryText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ═══ TAB 2: HISTORY (Timeline Diff) ═══ -->
                <TabItem Header="History" FontSize="11" FontWeight="SemiBold" Cursor="Hand" Padding="12,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Action Bar: Create Milestone snapshot -->
                        <Border Grid.Row="0" Padding="8,6" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                            <Button Content="Create Milestone ⭐️"
                                    Click="CreateMilestoneButton_Click"
                                    Background="{DynamicResource AccentColor}" Foreground="White"
                                    BorderThickness="0" Padding="10,6" FontSize="11" FontWeight="SemiBold"
                                    Cursor="Hand" HorizontalAlignment="Stretch"/>
                        </Border>

                        <!-- Timeline List -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding ChapterVersions}"
                                 Background="Transparent" BorderThickness="0" Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,8" Margin="0,2" CornerRadius="6"
                                            Background="{DynamicResource ControlBackground}"
                                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Date and Type badge -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                           FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryText}"/>
                                                
                                                <!-- Milestone Badge -->
                                                <Border Grid.Column="1" Padding="4,1" CornerRadius="3" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1E88E5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMilestone}" Value="True">
                                                                    <Setter Property="Background" Value="#F57C00"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="8" FontWeight="Bold" Foreground="White" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="AUTOSAVE"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMilestone}" Value="True">
                                                                        <Setter Property="Text" Value="MILESTONE"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Author metadata -->
                                            <TextBlock Grid.Row="1" Text="{Binding CreatedBy, StringFormat='By: {0}'}"
                                                       FontSize="10" Foreground="{DynamicResource SecondaryText}" Margin="0,4,0,6"/>

                                            <!-- Action buttons -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="Compare Diff"
                                                        Command="{Binding DataContext.CompareDiffCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#37474F" Foreground="White"
                                                        BorderThickness="0" Margin="0,0,3,0" Padding="5,4" FontSize="10" Cursor="Hand"/>
                                                <Button Grid.Column="1" Content="Restore"
                                                        Command="{Binding DataContext.RestoreVersionCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#1B5E20" Foreground="White"
                                                        BorderThickness="0" Margin="3,0,0,0" Padding="5,4" FontSize="10" Cursor="Hand"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Empty state history -->
                        <TextBlock Grid.Row="1" Text="No history snapshots available yet."
                                   FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                   Padding="12,20" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ChapterVersions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <!-- ═══ COLOR PICKER POPUP ═══ -->
        <Popup x:Name="ColorPickerPopup" StaysOpen="False" Placement="Mouse" AllowsTransparency="True">
            <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel>
                    <TextBlock x:Name="ColorPickerTitle" Text="Font Color" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,6"/>
                    <WrapPanel x:Name="ColorPalettePanel" Width="200"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>
