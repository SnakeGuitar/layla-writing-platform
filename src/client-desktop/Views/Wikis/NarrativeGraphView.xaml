<Page x:Class="Layla.Desktop.Views.Wikis.NarrativeGraphView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="NarrativeGraphView"
      Background="{DynamicResource CyberBgPrimaryBrush}"
      Foreground="{DynamicResource CyberTextPrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="20,10" Background="{DynamicResource CyberBgSecondaryBrush}"
                BorderBrush="{DynamicResource CyberBorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="NARRATIVE GRAPH" Style="{StaticResource CyberDisplayText}" FontSize="18"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentPrimaryBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Legend -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberAccentPrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Character" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberTextPrimaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Location" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberAccentWarningBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Event" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                        <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberTextSecondaryBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Object" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Border Width="6" Height="6" CornerRadius="0" Background="{DynamicResource CyberTextDisabledBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Concept" Style="{StaticResource CyberLabel}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button x:Name="AddRelationshipButton" Content="ADD RELATIONSHIP" Command="{Binding OpenAddRelationshipCommand}"
                            Style="{StaticResource CyberButton}" Padding="10,4" Margin="0,0,8,0" Cursor="Hand" FontSize="11"/>
                    
                    <Button Content="REFRESH" Command="{Binding LoadGraphCommand}"
                            Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"
                            Padding="10,4" Cursor="Hand" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="{DynamicResource CyberBgPrimaryBrush}">
            <Canvas x:Name="GraphCanvas" Width="1200" Height="800"
                    Background="{DynamicResource CyberBgSecondaryBrush}" Margin="20"
                    MouseLeftButtonDown="GraphCanvas_MouseLeftButtonDown"
                    MouseMove="GraphCanvas_MouseMove"
                    MouseLeftButtonUp="GraphCanvas_MouseLeftButtonUp"/>
        </ScrollViewer>

        <!-- ═══ Add Relationship Modal ═══ -->
        <Border Visibility="{Binding IsAddRelationshipVisible, Converter={StaticResource BoolToVis}}"
                Background="#CC000000" Panel.ZIndex="100" Grid.RowSpan="2">
            <Border Style="{StaticResource CyberPanelBorder}" Background="{DynamicResource CyberBgElevatedBrush}" Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="ADD RELATIONSHIP" Style="{StaticResource CyberDisplayText}" FontSize="18" Margin="0,0,0,15"/>

                    <TextBlock Text="SOURCE ENTITY:" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableEntities}"
                               SelectedItem="{Binding NewRelSource}"
                               DisplayMemberPath="Name" Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="TARGET ENTITY:" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableEntities}"
                               SelectedItem="{Binding NewRelTarget}"
                               DisplayMemberPath="Name" Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="RELATIONSHIP TYPE:" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding RelationshipTypes}"
                               SelectedItem="{Binding NewRelType}" Height="30" Margin="0,0,0,10"/>

                    <TextBlock Text="LABEL (OPTIONAL):" Style="{StaticResource CyberLabel}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewRelLabel, UpdateSourceTrigger=PropertyChanged}"
                              Height="28" Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding AddRelError}" Style="{StaticResource CyberTechMonoText}" Foreground="{DynamicResource CyberAccentWarningBrush}" FontSize="11"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Style="{StaticResource CyberButton}" Padding="15,6" Margin="0,0,8,0" Cursor="Hand"
                                Command="{Binding CancelAddRelationshipCommand}"/>
                        <Button Content="CREATE" Style="{StaticResource CyberButton}" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}" Foreground="{DynamicResource CyberAccentPrimaryBrush}" Padding="15,6"
                                Cursor="Hand" Command="{Binding ConfirmAddRelationshipCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
