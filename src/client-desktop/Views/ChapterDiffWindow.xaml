<Window x:Class="Layla.Desktop.Views.ChapterDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VERSION COMPARISON - LAYLA" Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CyberBgPrimaryBrush}"
        Foreground="{DynamicResource CyberTextPrimaryBrush}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Info -->
        <Border Grid.Row="0" Padding="15,10" Style="{StaticResource CyberPanelBorder}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="COMPARE VERSION" Style="{StaticResource CyberLabel}" Foreground="{DynamicResource CyberAccentPrimaryBrush}"/>
                    <TextBlock x:Name="VersionInfoText" Text="Comparing selected version with current editor text" Style="{StaticResource CyberTitleText}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource CyberButton}" Content="RESTORE TO THIS VERSION" Padding="16,8" VerticalAlignment="Center" Click="RestoreButton_Click"/>
            </Grid>
        </Border>

        <!-- Legend -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                <Border Width="12" Height="12" CornerRadius="0" Background="{DynamicResource CyberBgSecondaryBrush}" BorderBrush="{DynamicResource CyberAccentWarningBrush}" BorderThickness="1" Margin="0,0,6,0"/>
                <TextBlock Text="REMOVED CONTENT (AMBER STRIKETHROUGH)" Style="{StaticResource CyberLabel}" Foreground="{DynamicResource CyberAccentWarningBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="12" Height="12" CornerRadius="0" Background="{DynamicResource CyberBgSecondaryBrush}" BorderBrush="{DynamicResource CyberAccentPrimaryBrush}" BorderThickness="1" Margin="0,0,6,0"/>
                <TextBlock Text="ADDED CONTENT (CYAN HIGHLIGHT)" Style="{StaticResource CyberLabel}" Foreground="{DynamicResource CyberAccentPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </WrapPanel>

        <!-- Diff Viewer -->
        <Border Grid.Row="2" Style="{StaticResource CyberPanelBorder}" Padding="10">
            <RichTextBox x:Name="DiffRichTextBox" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="13" FontFamily="{StaticResource TechnicalFont}" Foreground="{DynamicResource CyberTextPrimaryBrush}" VerticalScrollBarVisibility="Auto">
                <FlowDocument x:Name="DiffFlowDocument">
                    <Paragraph x:Name="DiffParagraph">
                        <!-- Diff runs will be injected dynamically -->
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="3" Style="{StaticResource CyberButton}" Content="CLOSE PANEL" Width="100" HorizontalAlignment="Right" Margin="0,12,0,0" Click="CloseButton_Click"/>
    </Grid>
</Window>
