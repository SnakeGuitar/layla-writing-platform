<Window x:Class="Layla.Desktop.Views.ChapterDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Version Comparison - Layla" Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PrimaryText}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Info -->
        <Border Grid.Row="0" Padding="15,10" CornerRadius="6" Background="{DynamicResource SidebarBackground}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="COMPARE VERSION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock x:Name="VersionInfoText" Text="Comparing selected version with current editor text" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Restore to this Version" Background="#2E7D32" Foreground="White" BorderThickness="0" Padding="12,6" FontWeight="SemiBold" Cursor="Hand" Click="RestoreButton_Click"/>
            </Grid>
        </Border>

        <!-- Legend -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                <Border Width="12" Height="12" CornerRadius="2" Background="#FFEBEE" BorderBrush="#E57373" BorderThickness="1" Margin="0,0,4,0"/>
                <TextBlock Text="Removed Content (Red Strikethrough)" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="12" Height="12" CornerRadius="2" Background="#E8F5E9" BorderBrush="#81C784" BorderThickness="1" Margin="0,0,4,0"/>
                <TextBlock Text="Added Content (Green)" FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
            </StackPanel>
        </WrapPanel>

        <!-- Diff Viewer -->
        <Border Grid.Row="2" Background="{DynamicResource ControlBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="10">
            <RichTextBox x:Name="DiffRichTextBox" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontSize="14" FontFamily="Segoe UI" VerticalScrollBarVisibility="Auto">
                <FlowDocument x:Name="DiffFlowDocument">
                    <Paragraph x:Name="DiffParagraph">
                        <!-- Diff runs will be injected dynamically -->
                    </Paragraph>
                </FlowDocument>
            </RichTextBox>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="3" Content="Close Panel" Width="100" HorizontalAlignment="Right" Margin="0,12,0,0" Padding="8,4" Cursor="Hand" Click="CloseButton_Click"/>
    </Grid>
</Window>
