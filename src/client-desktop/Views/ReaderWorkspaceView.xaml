<Page x:Class="Layla.Desktop.Views.ReaderWorkspaceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1080"
      ShowsNavigationUI="False"
      Title="Reader Workspace"
      Background="{DynamicResource WindowBackground}"
      Foreground="{DynamicResource PrimaryText}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
            <ColumnDefinition Width="2"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding CurrentProject.Title}" FontWeight="Bold" FontSize="16"
                           VerticalAlignment="Center" Margin="15,10" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource AccentColor}"/>

                <!-- Author status indicator -->
                <Border Grid.Row="1" Margin="15,0,15,10" Padding="8,5" CornerRadius="4"
                        Background="{DynamicResource ControlBackground}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="Gray"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthorActive}" Value="True">
                                            <Setter Property="Fill" Value="LimeGreen"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding AuthorStatusText}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                    </StackPanel>
                </Border>

                <!-- Read-only badge -->
                <StackPanel Grid.Row="2" Margin="15,0">
                    <Border Background="#44FFD700" CornerRadius="4" Padding="8,5" Margin="0,0,0,10">
                        <TextBlock Text="READ-ONLY MODE" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{Binding CurrentProject.Synopsis}" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryText}" FontStyle="Italic">
                        <Run Text="Genre: "/><Run Text="{Binding CurrentProject.LiteraryGenre}"/>
                    </TextBlock>

                    <Button Content="← Back to Public Projects" Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Left" Padding="0,10"
                            Foreground="{DynamicResource SecondaryText}" Cursor="Hand"
                            Command="{Binding BackToPublicProjectsCommand}"/>
                </StackPanel>

                <Button Grid.Row="3" Content="🚪 Logout" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Left" Padding="15,10"
                        Foreground="IndianRed" Cursor="Hand"
                        Command="{Binding LogoutCommand}"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderColor}" Cursor="SizeWE"/>

        <!-- Main content area with tabs -->
        <Grid Grid.Column="2" Background="{DynamicResource ControlBackground}">
            <TabControl Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,0,5,0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="Manuscript (Read-Only)">
                    <Frame x:Name="EditorFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Wiki">
                    <Frame x:Name="WikiFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Graph">
                    <Frame x:Name="GraphFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>

                <TabItem Header="Voice">
                    <Frame x:Name="VoiceFrame" NavigationUIVisibility="Hidden"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Page>
