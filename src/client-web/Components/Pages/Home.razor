@page "/"
@page "/home"
@using client_web.Components.Components
<PageTitle>Home</PageTitle>

@* Header *@
<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Proyectos</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        Biblioteca pública
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

@* Feed Grid *@
<main class="max-w-5xl mx-auto">
    @if (projects == null || !projects.Any())
    {
        <p class="text-stone-500 text-sm">No hay proyectos disponibles.</p>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-stone-800">
            @foreach (ProjectViewModel project in projects)
            {
                <div class="bg-stone-950">
                    <ProjectCard Id="@project.Id" Title="@project.Title"
                                    Synopsis="@project.Synopsis"
                                    LiteraryGenre="@project.LiteraryGenre"
                                    CoverImageUrl="@project.CoverImageUrl"
                                    UpdatedAt="@project.UpdatedAt"
                                    OnCardClick="HandleCardClick" />
                </div>
            }
        </div>
    }
</main>

@code {
    private List<ProjectViewModel>? projects;

    protected override void OnInitialized()
    {
        // Replace with your actual data service call, e.g.:
        // projects = await ProjectService.GetAllAsync();

        projects = new List<ProjectViewModel>
        {
            new ProjectViewModel() {
                Id = Guid.NewGuid(),
                Title = "El último jardín de los sueños",
                Synopsis = "Una historia sobre la memoria, los sueños y los jardines secretos que guardamos en lo más profundo de nuestra mente.",
                LiteraryGenre = "Fantasía",
                CoverImageUrl = null,
                UpdatedAt = DateTime.Now.AddDays(-3)
            },
            new ProjectViewModel() {
                Id = Guid.NewGuid(),
                Title = "Cartas desde el fin del mundo",
                Synopsis = "Un epistolario íntimo que recorre los últimos días de una civilización a través de las cartas de quienes la vivieron.",
                LiteraryGenre = "Ciencia Ficción",
                CoverImageUrl = null,
                UpdatedAt = DateTime.Now.AddDays(-10)
            },
            new ProjectViewModel() {
                Id = Guid.NewGuid(),
                Title = "La ciudad de los espejos rotos",
                Synopsis = "Un detective sin pasado investiga desapariciones en una ciudad donde los espejos muestran lo que pudo haber sido.",
                LiteraryGenre = "Noir",
                CoverImageUrl = null,
                UpdatedAt = DateTime.Now.AddDays(-1)
            },
        };
    }

    private void HandleCardClick(Guid projectId)
    {
        // Navigate to project detail, e.g.:
        // NavigationManager.NavigateTo($"/projects/{projectId}");
        Console.WriteLine($"Clicked project: {projectId}");
    }

    private class ProjectViewModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Synopsis { get; set; } = string.Empty;
        public string LiteraryGenre { get; set; } = string.Empty;
        public string? CoverImageUrl { get; set; }
        public DateTime UpdatedAt { get; set; }
    }
}
