@page "/about"

<PageTitle>About</PageTitle>

<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Layla</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        About this project
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

<div class="max-w-3xl mx-auto text-stone-300 space-y-4 leading-relaxed">
    <p>
        Layla is a collaborative creative-writing platform. Authors co-write
        novels, build worldbuilding wikis, and visualise narrative graphs in
        real time.
    </p>
    <p>
        This web client is one of three Layla front-ends — alongside a WPF
        desktop application (the main authoring workspace) and an Android
        companion. All three talk to the same backend pair: an ASP.NET Core
        API for identity and projects, and a Node.js worldbuilding service
        backed by MongoDB and Neo4j.
    </p>
    <p class="text-stone-500 text-sm">
        v1.0.0
    </p>
</div>
