@page "/projects/my-projects"
@using client_web.Application.Services.Projects
@using client_web.Application.Services.Session
@using client_web.Models
@using client_web.UI.Components
@inject IProjectService ProjectService
@inject ISessionManager Session
@inject NavigationManager Navigation

<PageTitle>My Projects // Secure Registry</PageTitle>

<header class="max-w-5xl mx-auto mb-8 border-b border-[var(--border-subtle)] pb-4">
    <span class="text-cyber-metadata">SYS_REGISTRY // OPERATOR_UNITS</span>
    <h1 class="text-cyber-display mt-1 uppercase">My Projects</h1>
</header>

<AuthorizeView>
    <Authorized>
        @if (_loading)
        {
            <p class="text-cyber-tech-mono text-sm text-[var(--text-disabled)]">LOADING MY PROJECTS...</p>
        }
        else if (_projects is null || _projects.Count == 0)
        {
            <p class="text-cyber-tech-mono text-sm text-[var(--text-disabled)]">NO REGISTERED PROJECTS DETECTED.</p>
        }
        else
        {
            <div class="grid md:grid-cols-2 sm:grid-cols-1 gap-4 bg-transparent">
                @foreach (var project in _projects)
                {
                    <div>
                        <ProjectCard2 Id="@project.Id"
                                      Title="@project.Title"
                                      Synopsis="@project.Synopsis"
                                      LiteraryGenre="@project.LiteraryGenre"
                                      CoverImageUrl="@project.CoverImageUrl"
                                      UpdatedAt="@project.UpdatedAt"
                                      UserRole="@project.UserRole"
                                      OnCardClick="HandleCardClick" />
                    </div>
                }
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <p class="text-cyber-body">
            Security key missing. Please <a href="/auth/login" class="text-[var(--accent-primary)] hover:underline">[ SIGN IN ]</a>
            to access personal project streams.
        </p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<Project>? _projects;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var hadToken = Session.IsAuthenticated;
        var restored = await Session.InitializeAsync();
        if (restored && !hadToken)
        {
            await LoadProjectsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadProjectsAsync()
    {
        _loading = true;
        try
        {
            if (!Session.IsAuthenticated)
            {
                _projects = new List<Project>();
                return;
            }
            var result = await ProjectService.GetMyProjectsAsync();
            _projects = result.ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleCardClick(Guid projectId)
    {
        Navigation.NavigateTo($"/projects/{projectId}", forceLoad: true);
    }
}
