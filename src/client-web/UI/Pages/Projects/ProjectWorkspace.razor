@page "/projects/{ProjectId:guid}"
@using client_web.Application.Services.Projects
@using client_web.Application.Services.Session
@using client_web.Models
@using client_web.UI.Components.Workspace
@inject IProjectService ProjectService
@inject ISessionManager Session
@inject NavigationManager Navigation

<PageTitle>@(_project?.Title ?? "Workspace") // System Core</PageTitle>

<div class="max-w-7xl mx-auto space-y-4">
    @if (_loading)
    {
        <div class="flex items-center justify-center py-16">
            <p class="text-cyber-tech-mono text-sm text-[var(--text-disabled)] animate-pulse">ESTABLISHING WORKSPACE STREAMS...</p>
        </div>
    }
    else if (_project == null)
    {
        <div class="cyber-panel p-6 max-w-lg mx-auto text-center mt-12 border-[var(--accent-warning)] bg-[var(--bg-primary)]">
            <h3 class="text-cyber-title text-[var(--accent-warning)] mb-2 uppercase">Access Refused</h3>
            <p class="text-cyber-body text-xs mb-4">The requested project stream does not exist or your identity unit lacks read authorization.</p>
            <a href="/projects/my-projects" class="cyber-button text-xs inline-flex">
                [ Return to List ]
            </a>
        </div>
    }
    else
    {
        <!-- Header -->
        <header class="cyber-panel p-4 bg-[var(--bg-secondary)]">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div class="space-y-1">
                    <div class="flex items-center gap-2">
                        <span class="text-cyber-metadata">SYS_WORKSPACE</span>
                        <span class="px-2 py-0.5 bg-[var(--bg-primary)] border border-[var(--border-subtle)] text-cyber-metadata text-[10px]">
                            @_project.LiteraryGenre
                        </span>
                        @if (!string.IsNullOrEmpty(_project.UserRole))
                        {
                            <span class="px-2 py-0.5 bg-[var(--bg-primary)] border border-[var(--accent-primary)] text-[var(--accent-primary)] text-cyber-metadata text-[10px]">
                                @_project.UserRole.ToUpper()
                            </span>
                        }
                    </div>
                    <h1 class="text-cyber-display uppercase mt-1">
                        @_project.Title
                    </h1>
                    <p class="text-cyber-body text-xs max-w-3xl">
                        @_project.Synopsis
                    </p>
                </div>
                <div class="shrink-0 flex gap-2 items-center">
                    <button @onclick="ToggleVoiceDrawer"
                            id="voice-toggle-btn"
                            class="cyber-button text-xs py-1 px-3">
                        [ VOICE_LINK ]
                    </button>
                    <a href="/projects/my-projects" class="cyber-button text-xs py-1 px-3">
                        [ BACK ]
                    </a>
                </div>
            </div>
        </header>

        <!-- Navigation Tabs -->
        <div class="border-b border-[var(--border-subtle)] pb-px">
            <nav class="flex gap-4" aria-label="Tabs">
                @foreach (var tab in _tabs)
                {
                    var isSelected = _activeTab == tab.Id;
                    <button @onclick="() => SetActiveTab(tab.Id)"
                            class="pb-2 text-xs font-mono uppercase tracking-wider relative transition-all duration-100 outline-none
                                   @(isSelected ? "text-[var(--accent-primary)]" : "text-[var(--text-secondary)] hover:text-[var(--text-primary)]")">
                        @tab.Label
                        @if (isSelected)
                        {
                            <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-[var(--accent-primary)]"></div>
                        }
                    </button>
                }
            </nav>
        </div>

        <!-- Dynamic Content -->
        <div class="transition-opacity duration-100">
            @if (_activeTab == "manuscript")
            {
                <ManuscriptTab ProjectId="ProjectId" />
            }
            else if (_activeTab == "wiki")
            {
                <WikiTab ProjectId="ProjectId" />
            }
            else if (_activeTab == "graph")
            {
                <GraphTab ProjectId="ProjectId" />
            }
        </div>

        <VoiceDrawer ProjectId="ProjectId" @bind-IsOpen="_voiceDrawerOpen" />
    }
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private Project? _project;
    private bool _loading = true;
    private string _activeTab = "manuscript";
    private bool _voiceDrawerOpen = false;

    private void ToggleVoiceDrawer()
    {
        _voiceDrawerOpen = !_voiceDrawerOpen;
    }

    private readonly List<(string Id, string Label)> _tabs = new()
    {
        ("manuscript", "Manuscripts"),
        ("wiki", "Wiki Lorebook"),
        ("graph", "Relational Graph")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadProjectAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var hadToken = Session.IsAuthenticated;
        var restored = await Session.InitializeAsync();
        if (restored && !hadToken)
        {
            await LoadProjectAsync();
            StateHasChanged();
        }
    }

    private async Task LoadProjectAsync()
    {
        _loading = true;
        try
        {
            if (!Session.IsAuthenticated)
            {
                _project = null;
                return;
            }
            _project = await ProjectService.GetProjectByIdAsync(ProjectId);
        }
        catch (Exception)
        {
            _project = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetActiveTab(string tabId)
    {
        _activeTab = tabId;
    }
}
