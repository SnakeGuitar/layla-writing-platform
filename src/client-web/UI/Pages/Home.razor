@page "/"
@page "/home"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using client_web.Application.Services.ActiveStatusAuthor
@using client_web.Application.Services.Projects
@using client_web.Application.Services.Session
@using client_web.UI.Components
@inject IPresenceService PresenceService
@inject IProjectService ProjectService
@inject ISessionManager Session
@inject ILogger<Home> Logger
@implements IAsyncDisposable

<PageTitle>Home // Public Library</PageTitle>

@* Header *@
<header class="max-w-5xl mx-auto mb-8 border-b border-[var(--border-subtle)] pb-4">
    <span class="text-cyber-metadata">SYS_ARCHIVE // DIRECTORY</span>
    <h1 class="text-cyber-display mt-1 uppercase">
        Public Library
    </h1>
</header>

@* Feed Grid *@
@if (_projects is null)
{
    <p class="text-stone-500 text-sm">Loading…</p>
}
else if (_projects.Count == 0)
{
    <p class="text-stone-500 text-sm">No projects available.</p>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px">
        @foreach (var project in _projects)
        {
            <div>
                <ProjectCard Id="@project.Id"
                             Title="@project.Title"
                             Synopsis="@project.Synopsis"
                             LiteraryGenre="@project.LiteraryGenre"
                             CoverImageUrl="@project.CoverImageUrl"
                             UpdatedAt="@project.UpdatedAt"
                             IsAuthorActive="@project.IsAuthorActive"
                             OnCardClick="HandleCardClick" />
            </div>
        }
    </div>
}

@code {
    private List<ProjectViewModel>? _projects;
    private bool _presenceConnected;

    protected override async Task OnInitializedAsync()
    {
        PresenceService.OnAuthorStatusChanged += HandleAuthorStatusChanged;

        var dtos = await ProjectService.GetPublicProjectsAsync();
        _projects = dtos.Select(p => new ProjectViewModel
        {
            Id = p.Id,
            Title = p.Title,
            Synopsis = p.Synopsis,
            LiteraryGenre = p.LiteraryGenre,
            CoverImageUrl = p.CoverImageUrl,
            UpdatedAt = p.UpdatedAt,
        }).ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Hydrate the session from browser storage now that JS interop is
        // available. Connect the presence hub with the resolved token (or
        // anonymously if there isn't one).
        await Session.InitializeAsync();

        if (_presenceConnected) return;
        try
        {
            await PresenceService.ConnectAsync(Session.CurrentToken ?? string.Empty);
            _presenceConnected = PresenceService.IsConnected;

            if (_presenceConnected && _projects is not null)
            {
                foreach (var p in _projects)
                    await PresenceService.WatchProjectAsync(p.Id);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Could not connect to the presence hub.");
        }
    }

    private void HandleAuthorStatusChanged(object? sender, AuthorStatusChangedEventArgs e)
    {
        var project = _projects?.FirstOrDefault(p => p.Id == e.ProjectId);
        if (project is null) return;
        project.IsAuthorActive = e.IsActive;
        InvokeAsync(StateHasChanged);
    }

    private void HandleCardClick(Guid projectId)
    {
        // TODO: NavigationManager.NavigateTo($"/projects/{projectId}");
        Logger.LogInformation("Clicked project: {ProjectId}", projectId);
    }

    public async ValueTask DisposeAsync()
    {
        PresenceService.OnAuthorStatusChanged -= HandleAuthorStatusChanged;
        await PresenceService.DisposeAsync();
    }

    private class ProjectViewModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Synopsis { get; set; } = string.Empty;
        public string LiteraryGenre { get; set; } = string.Empty;
        public string? CoverImageUrl { get; set; }
        public DateTime UpdatedAt { get; set; }
        public bool IsAuthorActive { get; set; }
    }
}
