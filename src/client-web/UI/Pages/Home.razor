@page "/"
@page "/home"
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.Extensions.Http
@using client_web.Application.Config.Http
@using client_web.Application.Config.SignalR
@using client_web.Application.Services.Projects
@using client_web.UI.Components
@using client_web.Application.Services.ActiveStatusAuthor
@inject IPresenceService PresenceService
@inject IProjectService ProjectService
@inject ILogger<Home> Logger
@implements IAsyncDisposable
<PageTitle>Home</PageTitle>

@* Header *@
<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Projects</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        Public Library
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

@* Feed Grid *@
@if (projects == null)
{
    <p class="text-stone-500 text-sm">Loading...</p>
}
else if (!projects.Any())
{
    <p class="text-stone-500 text-sm">No projects available.</p>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px">
        @foreach (ProjectViewModel project in projects)
        {
            <div>
                <ProjectCard Id="@project.Id" Title="@project.Title" Synopsis="@project.Synopsis"
                             LiteraryGenre="@project.LiteraryGenre" CoverImageUrl="@project.CoverImageUrl" UpdatedAt="@project.UpdatedAt"
                             IsAuthorActive="@project.IsAuthorActive" OnCardClick="HandleCardClick" />
            </div>
        }
    </div>
}

@code {
    private string _token = "";
    private List<ProjectViewModel>? projects;

    protected override async Task OnInitializedAsync()
    {
        PresenceService.OnAuthorStatusChanged += HandleAuthorStatusChanged;

        List<PublicProjectDto>? dtos = await ProjectService.GetPublicProjectsAsync();
        projects = dtos.Select(p => new ProjectViewModel
        {
            Id = p.Id,
            Title = p.Title,
            Synopsis = p.Synopsis,
            LiteraryGenre = p.LiteraryGenre,
            CoverImageUrl = p.CoverImageUrl,
            UpdatedAt = p.UpdatedAt
        }).ToList();

        await PresenceService.ConnectAsync(_token);

        if (PresenceService.IsConnected)
            foreach (ProjectViewModel p in projects)
                await PresenceService.WatchProjectAsync(p.Id);
    }

    private void HandleAuthorStatusChanged(object? sender, AuthorStatusChangedEventArgs e)
    {
        ProjectViewModel? project = projects?.FirstOrDefault(p => p.Id == e.ProjectId);

        if (project != null)
        {
            project.IsAuthorActive = e.IsActive;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleCardClick(Guid projectId)
    {
        // TODO: NavigationManager.NavigateTo($"/projects/{projectId}");
        Console.WriteLine(value: $"Clicked project: {projectId}");
    }

    public async ValueTask DisposeAsync()
    {
        PresenceService.OnAuthorStatusChanged -= HandleAuthorStatusChanged;
        await PresenceService.DisposeAsync();
    }

    private class ProjectViewModel
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Synopsis { get; set; } = string.Empty;
        public string LiteraryGenre { get; set; } = string.Empty;
        public string? CoverImageUrl { get; set; }
        public DateTime UpdatedAt { get; set; }
        public bool IsAuthorActive { get; set; }
    }
}
