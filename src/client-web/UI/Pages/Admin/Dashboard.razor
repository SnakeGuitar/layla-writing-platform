@page "/admin/dashboard"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using client_web.Application.Services.Admin
@using client_web.Application.Services.Session
@inject IAdminService AdminService
@inject ISessionManager Session
@inject IJSRuntime JS
@inject ILogger<Dashboard> Logger

<PageTitle>Administration</PageTitle>

<header class="max-w-5xl mx-auto mb-12">
    <h2 class="text-amber-500 text-xs font-bold tracking-[0.3em] uppercase mb-3">Administration</h2>
    <h1 class="text-stone-100 font-serif text-4xl md:text-5xl font-light tracking-tight">
        Dashboard
    </h1>
    <div class="mt-4 w-16 h-px bg-amber-500"></div>
</header>

@if (_loading)
{
    <p class="text-stone-500 text-sm">Loading…</p>
}
else if (_error is not null)
{
    <p class="text-red-400 text-sm">@_error</p>
}
else if (_stats is not null)
{
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-4 mb-8 max-w-5xl mx-auto">
        <StatCard Label="Total Users"            Value="@_stats.TotalUsers" />
        <StatCard Label="New Users This Month"   Value="@_stats.NewUsersThisMonth" />
        <StatCard Label="Banned Users"           Value="@_stats.BannedUsers" />
        <StatCard Label="Total Projects"         Value="@_stats.TotalProjects" />
        <StatCard Label="Modified Today"         Value="@_stats.ProjectsModifiedToday" />
        <StatCard Label="Public Projects"        Value="@_stats.PublicProjects" />
    </div>

    <div class="max-w-5xl mx-auto bg-base-gray-2 rounded-lg p-6 shadow">
        <h3 class="text-stone-200 text-sm font-semibold tracking-wide uppercase mb-4">
            New users — last 12 months
        </h3>
        <canvas id="adminUsersChart" width="800" height="280"></canvas>
    </div>
}

@code {
    private DashboardStats? _stats;
    private bool _loading = true;
    private string? _error;
    private bool _chartRendered;

    protected override async Task OnInitializedAsync()
    {
        // Hydrate the session early so the JWT is on hand when LoadAsync hits
        // /api/users (Authorize=Admin). InitializeAsync is no-op during the
        // prerender pass and replays from OnAfterRenderAsync via StateHasChanged.
        await Session.InitializeAsync();
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // ProtectedSessionStorage isn't available during prerender — retry.
            var hadToken = Session.IsAuthenticated;
            await Session.InitializeAsync();
            if (!hadToken && Session.IsAuthenticated)
            {
                await LoadAsync();
                StateHasChanged();
            }
        }

        if (_stats is not null && !_chartRendered)
        {
            try
            {
                await JS.InvokeVoidAsync("createBarChart", "adminUsersChart", _stats.NewUsersPerMonth);
                _chartRendered = true;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not render the dashboard chart.");
            }
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _stats = await AdminService.GetDashboardStatsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard stats.");
            _error = "Could not load dashboard data.";
        }
        finally
        {
            _loading = false;
        }
    }

}
