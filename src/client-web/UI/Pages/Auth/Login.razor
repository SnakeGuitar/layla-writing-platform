@page "/auth/login"
@layout client_web.UI.Layout.LayoutEmpty
@rendermode InteractiveServer
@using client_web.Application.Schemas.Auth
@using client_web.Application.Services.Auth
@using client_web.Application.Services.Session
@inject IAuthService AuthService
@inject ISessionManager Session
@inject NavigationManager Navigation

<PageTitle>Login // System Access</PageTitle>

<main class="flex items-center justify-center px-4 min-h-screen bg-[var(--bg-primary)]">

    <!-- Monolithic Technical Panel -->
    <div class="cyber-panel w-full max-w-sm">
        
        <!-- Header -->
        <header class="cyber-panel-header">
            <div class="flex flex-col">
                <span class="text-cyber-metadata">SECURE ACCESS</span>
                <h1 class="text-cyber-title mt-1">OPERATOR SIGN IN</h1>
            </div>
            <span class="text-cyber-tech-mono text-[var(--accent-primary)]">SYS_OK</span>
        </header>

        <!-- Form Elements -->
        <div class="space-y-4">

            <!-- Email -->
            <div class="cyber-input-wrapper">
                <label class="cyber-label">Operational Email</label>
                <input
                    type="email"
                    @bind="_email"
                    placeholder="operator@system.core"
                    class="cyber-input w-full" />
                @if (_fieldErrors.TryGetValue("Email", out var emailErrors))
                {
                    <p class="mt-1 text-cyber-tech-mono text-xs text-[var(--accent-warning)]">@string.Join(' ', emailErrors)</p>
                }
            </div>

            <!-- Password -->
            <div class="cyber-input-wrapper">
                <div class="flex justify-between items-center">
                    <label class="cyber-label">Security Key</label>
                    <a href="#" class="text-cyber-caption hover:text-[var(--accent-primary)] text-xs">
                        [ Recover Key ]
                    </a>
                </div>
                <input
                    type="password"
                    @bind="_password"
                    @onkeyup="@(e => { if (e.Key == "Enter") _ = HandleLogin(); })"
                    placeholder="••••••••"
                    class="cyber-input w-full" />
                @if (_fieldErrors.TryGetValue("Password", out var pwErrors))
                {
                    <p class="mt-1 text-cyber-tech-mono text-xs text-[var(--accent-warning)]">@string.Join(' ', pwErrors)</p>
                }
            </div>

            <!-- Error Notification Panel -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="p-3 bg-[var(--bg-primary)] border border-[var(--accent-warning)] text-[var(--accent-warning)] text-xs font-mono">
                    <span class="font-bold">[ ERROR ]</span> @_errorMessage
                </div>
            }

            <!-- Confirm Button -->
            <div class="pt-2">
                <button
                    @onclick="HandleLogin"
                    disabled="@_isLoading"
                    class="cyber-button w-full">
                    @if (_isLoading)
                    {
                        <span class="flex items-center justify-center gap-2">
                            <span>Executing Handshake...</span>
                        </span>
                    }
                    else
                    {
                        <span>Initialize Link →</span>
                    }
                </button>
            </div>

        </div>

        <!-- Footer options -->
        <footer class="mt-6 pt-4 border-t border-[var(--border-subtle)] text-center text-xs">
            <span class="text-cyber-body text-xs">No registered operator?</span>
            <a href="/auth/register" class="ml-1 text-cyber-tech-mono text-[var(--accent-primary)] hover:underline">
                [ Register New Unit ]
            </a>
        </footer>

    </div>
</main>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string? _errorMessage;
    private bool _isLoading;
    private Dictionary<string, List<string>> _fieldErrors = new();

    private async Task HandleLogin()
    {
        _errorMessage = null;
        _fieldErrors = new();
        _isLoading = true;

        try
        {
            var request = new LoginRequest { Email = _email, Password = _password };
            var result = await AuthService.LoginAsync(request);

            if (result.IsSuccess && result.Response is not null)
            {
                await Session.SaveAsync(result.Response);
                Navigation.NavigateTo("/home", forceLoad: true);
                return;
            }

            _errorMessage = result.ErrorMessage ?? "Handshake rejected.";
            _fieldErrors = result.ValidationErrors;
        }
        catch (Exception)
        {
            _errorMessage = "Link failure: service offline.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
