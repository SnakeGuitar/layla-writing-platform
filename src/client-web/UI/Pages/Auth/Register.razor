@page "/auth/register"
@layout client_web.UI.Layout.LayoutEmpty
@rendermode InteractiveServer
@using client_web.Application.Schemas.Auth
@using client_web.Application.Services.Auth
@using client_web.Application.Services.Session
@inject IAuthService AuthService
@inject ISessionManager Session
@inject NavigationManager Navigation

<PageTitle>Register // System Enlistment</PageTitle>

<main class="flex items-center justify-center px-4 min-h-screen bg-[var(--bg-primary)]">

    <!-- Monolithic Technical Panel -->
    <div class="cyber-panel w-full max-w-sm">

        @if (!_verificationStep)
        {
            <!-- ─── STAGE 1 — collect credentials ─────────────────────────────── -->
            <header class="cyber-panel-header">
                <div class="flex flex-col">
                    <span class="text-cyber-metadata">SYSTEM ENLISTMENT</span>
                    <h1 class="text-cyber-title mt-1">NEW OPERATOR REGISTRATION</h1>
                </div>
                <span class="text-cyber-tech-mono text-[var(--accent-primary)]">NEW_UNIT</span>
            </header>

            <div class="space-y-4">

                <!-- Display Name -->
                <div class="cyber-input-wrapper">
                    <label class="cyber-label">Callsign / Display Name</label>
                    <input type="text"
                           @bind="_displayName"
                           placeholder="Jane Author"
                           class="cyber-input w-full" />
                    @if (_fieldErrors.TryGetValue("DisplayName", out var nameErrors))
                    {
                        <p class="mt-1 text-cyber-tech-mono text-xs text-[var(--accent-warning)]">@string.Join(' ', nameErrors)</p>
                    }
                </div>

                <!-- Email -->
                <div class="cyber-input-wrapper">
                    <label class="cyber-label">Operational Email</label>
                    <input type="email"
                           @bind="_email"
                           placeholder="operator@system.core"
                           class="cyber-input w-full" />
                    @if (_fieldErrors.TryGetValue("Email", out var emailErrors))
                    {
                        <p class="mt-1 text-cyber-tech-mono text-xs text-[var(--accent-warning)]">@string.Join(' ', emailErrors)</p>
                    }
                </div>

                <!-- Password -->
                <div class="cyber-input-wrapper">
                    <label class="cyber-label">Security Key / Password</label>
                    <input type="password"
                           @bind="_password"
                           @onkeyup="@(e => { if (e.Key == "Enter") _ = HandleRegister(); })"
                           placeholder="••••••••"
                           class="cyber-input w-full" />
                    @if (_fieldErrors.TryGetValue("Password", out var pwErrors))
                    {
                        <p class="mt-1 text-cyber-tech-mono text-xs text-[var(--accent-warning)]">@string.Join(' ', pwErrors)</p>
                    }
                    else
                    {
                        <p class="text-cyber-metadata text-[10px]">Min 6 chars, 1 number, 1 uppercase.</p>
                    }
                </div>

                <!-- Error Notification Panel -->
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="p-3 bg-[var(--bg-primary)] border border-[var(--accent-warning)] text-[var(--accent-warning)] text-xs font-mono">
                        <span class="font-bold">[ ERROR ]</span> @_errorMessage
                    </div>
                }

                <!-- Submit Button -->
                <div class="pt-2">
                    <button @onclick="HandleRegister"
                            disabled="@_isLoading"
                            class="cyber-button w-full">
                        @if (_isLoading)
                        {
                            <span>Registering Unit...</span>
                        }
                        else
                        {
                            <span>Initialize Registration →</span>
                        }
                    </button>
                </div>
            </div>

            <!-- Footer options -->
            <footer class="mt-6 pt-4 border-t border-[var(--border-subtle)] text-center text-xs">
                <span class="text-cyber-body text-xs">Already registered?</span>
                <a href="/auth/login" class="ml-1 text-cyber-tech-mono text-[var(--accent-primary)] hover:underline">
                    [ Operator Login ]
                </a>
            </footer>
        }
        else
        {
            <!-- ─── STAGE 2 — submit the email PIN ───────────────────────────── -->
            <header class="cyber-panel-header">
                <div class="flex flex-col">
                    <span class="text-cyber-metadata">IDENTITY VERIFICATION</span>
                    <h1 class="text-cyber-title mt-1">VERIFY EMAIL PIN</h1>
                </div>
                <span class="text-cyber-tech-mono text-[var(--accent-warning)]">PENDING_PIN</span>
            </header>

            <div class="space-y-4">
                <div class="text-xs text-cyber-body mb-2">
                    Verification code dispatched to: <span class="text-cyber-tech-mono text-[var(--accent-primary)]">@_email</span>
                </div>

                <!-- PIN Input -->
                <div class="cyber-input-wrapper">
                    <label class="cyber-label">Verification PIN</label>
                    <input type="text"
                           inputmode="numeric"
                           autocomplete="one-time-code"
                           @bind="_pin"
                           @onkeyup="@(e => { if (e.Key == "Enter") _ = HandleVerify(); })"
                           placeholder="123456"
                           class="cyber-input w-full text-center tracking-widest font-mono" />
                </div>

                <!-- Messages -->
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="p-3 bg-[var(--bg-primary)] border border-[var(--accent-warning)] text-[var(--accent-warning)] text-xs font-mono">
                        <span class="font-bold">[ ERROR ]</span> @_errorMessage
                    </div>
                }

                @if (!string.IsNullOrEmpty(_infoMessage))
                {
                    <div class="p-3 bg-[var(--bg-primary)] border border-[var(--accent-primary)] text-[var(--accent-primary)] text-xs font-mono">
                        <span class="font-bold">[ SYSTEM ]</span> @_infoMessage
                    </div>
                }

                <!-- Verify Button -->
                <div class="pt-2">
                    <button @onclick="HandleVerify"
                            disabled="@_isLoading"
                            class="cyber-button w-full">
                        @if (_isLoading)
                        {
                            <span>Verifying...</span>
                        }
                        else
                        {
                            <span>Verify and Enlist →</span>
                        }
                    </button>
                </div>

                <!-- Back button -->
                <div class="pt-1 text-center">
                    <button @onclick="BackToForm"
                            class="text-cyber-caption hover:text-[var(--accent-primary)] text-xs">
                        [ ← Change Operational Email ]
                    </button>
                </div>
            </div>
        }

    </div>
</main>

@code {
    private string _displayName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _pin = string.Empty;

    private string? _errorMessage;
    private string? _infoMessage;
    private bool _isLoading;
    private bool _verificationStep;
    private Dictionary<string, List<string>> _fieldErrors = new();

    private async Task HandleRegister()
    {
        _errorMessage = null;
        _infoMessage = null;
        _fieldErrors = new();
        _isLoading = true;

        try
        {
            var request = new RegisterRequest
            {
                DisplayName = _displayName,
                Email = _email,
                Password = _password,
            };
            var result = await AuthService.RegisterAsync(request);

            if (result.IsSuccess)
            {
                _verificationStep = true;
                _password = string.Empty;
                _infoMessage = "Verification PIN dispatched to inbox.";
                return;
            }

            _errorMessage = result.ErrorMessage ?? "Registration rejected.";
            _fieldErrors = result.ValidationErrors;
        }
        catch (Exception)
        {
            _errorMessage = "Link failure: service offline.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleVerify()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var request = new VerifyEmailRequest { Email = _email, Pin = _pin };
            var result = await AuthService.VerifyEmailAsync(request);

            if (result.IsSuccess && result.Response is not null)
            {
                await Session.SaveAsync(result.Response);
                Navigation.NavigateTo("/home", forceLoad: true);
                return;
            }

            _errorMessage = result.ErrorMessage ?? "PIN verification failed.";
        }
        catch (Exception)
        {
            _errorMessage = "Verification failure: link offline.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BackToForm()
    {
        _verificationStep = false;
        _pin = string.Empty;
        _errorMessage = null;
        _infoMessage = null;
    }
}
