<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["styles/styles.css"]" />
    <link rel="stylesheet" href="@Assets["client-web.styles.css"]" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <HeadOutlet />
    <ImportMap />
</head>

<body>
    <Routes @rendermode="InteractiveServer"/>
    <!--
        autostart=false + Blazor.start({...}) lets us disable Blazor's
        "enhanced navigation". With enhanced nav on, clicking a NavLink only
        changed the URL and never re-applied the new server-rendered HTML
        (a known interaction between InteractiveServer rendermode and the
        streaming SSR pipeline). Disabling it makes each navigation a normal
        full-page load — reliable and predictable.
    -->
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            ssr: { disableDomPreservation: true }
        });
    </script>
</body>

</html>