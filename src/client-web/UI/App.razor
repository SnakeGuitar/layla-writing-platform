<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["styles/styles.css"]" />
    <link rel="stylesheet" href="@Assets["client-web.styles.css"]" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
    <ImportMap />
</head>

<body>
    <Routes @rendermode="InteractiveServer"/>
    <!--
        Let Blazor boot with its default config. The previous override
        (`autostart=false` + Blazor.start({ssr:{disableDomPreservation:true}}))
        was passing an option the WebAssembly/Server bootstrapper does not
        recognise on .NET 10, which silently broke client-side circuit start
        in some paths — the URL changed on NavLink clicks but the page
        content never updated until a manual reload. Default startup +
        InteractiveServer on <Routes/> gives reliable in-circuit navigation.
    -->
    <script src="_framework/blazor.web.js"></script>
    <script src="js/chart.umd.min.js"></script>
    <script src="js/chartInterop.js"></script>
</body>

</html>
