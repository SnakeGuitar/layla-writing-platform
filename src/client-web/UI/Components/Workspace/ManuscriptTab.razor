@using System.Threading
@using client_web.Application.Services.Manuscripts
@using client_web.Models.Worldbuilding
@using Microsoft.AspNetCore.Components.Web

@inject IManuscriptService ManuscriptService

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 h-[700px]">
    <!-- Left Panel: Tree View -->
    <div class="lg:col-span-1 p-4 bg-[var(--bg-secondary)] border border-[var(--border-subtle)] flex flex-col h-full overflow-hidden">
        <div class="flex items-center justify-between border-b border-[var(--border-subtle)] pb-2 mb-3 shrink-0">
            <h3 class="text-cyber-tech-mono text-xs text-[var(--text-secondary)] uppercase">Manuscripts</h3>
            <button @onclick="ToggleAddManuscriptForm" 
                    class="cyber-button text-[10px] py-0.5 px-2">
                [ + NEW MS ]
            </button>
        </div>

        @if (_showAddMsForm)
        {
            <div class="p-3 bg-[var(--bg-primary)] border border-[var(--border-subtle)] mb-3 shrink-0 space-y-2">
                <input @bind="_newMsTitle" placeholder="Manuscript Title" 
                       class="cyber-input text-xs w-full" />
                <div class="flex justify-end gap-2 text-xs">
                    <button @onclick="ToggleAddManuscriptForm" class="text-cyber-caption hover:text-[var(--accent-primary)] text-[10px]">[ CANCEL ]</button>
                    <button @onclick="CreateManuscriptAsync" class="cyber-button text-[10px] py-0.5 px-2">[ CREATE ]</button>
                </div>
            </div>
        }

        <!-- Manuscripts Tree Container -->
        <div class="flex-1 overflow-y-auto pr-1 space-y-2 text-sm text-[var(--text-secondary)]">
            @if (_loading)
            {
                <p class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] animate-pulse">LOADING MANUSCRIPTS...</p>
            }
            else if (_manuscripts == null || _manuscripts.Count == 0)
            {
                <p class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] py-4 text-center">NO REGISTERED MANUSCRIPTS.</p>
            }
            else
            {
                @foreach (var ms in _manuscripts)
                {
                    var isExpanded = _expandedMs.Contains(ms.ManuscriptId);
                    <div class="border border-[var(--border-subtle)] bg-[var(--bg-primary)] p-2 space-y-1">
                        <!-- Manuscript Title Block -->
                        <div class="flex items-center justify-between group">
                            <div class="flex items-center gap-2 cursor-pointer flex-1" @onclick="() => ToggleMsExpansion(ms.ManuscriptId)">
                                <span class="text-[var(--text-disabled)] text-xs select-none">
                                    @(isExpanded ? "▼" : "▶")
                                </span>
                                <span class="font-mono text-xs uppercase text-[var(--text-primary)] truncate">@ms.Title</span>
                            </div>
                            <div class="opacity-0 group-hover:opacity-100 flex gap-2 transition-all duration-100">
                                <button @onclick="() => ShowAddChapterForm(ms.ManuscriptId)" title="Add Chapter" class="text-[10px] text-[var(--accent-primary)] hover:underline">
                                    [ + CHAP ]
                                </button>
                                <button @onclick="() => DeleteManuscriptAsync(ms.ManuscriptId)" title="Delete Manuscript" class="text-[10px] text-[var(--accent-warning)] hover:underline">
                                    [ DEL ]
                                </button>
                            </div>
                        </div>

                        <!-- Chapters under this manuscript -->
                        @if (isExpanded)
                        {
                            <div class="pl-3 border-l border-[var(--border-subtle)] mt-1 space-y-1">
                                @if (_addingChapterMsId == ms.ManuscriptId)
                                {
                                    <div class="p-2 bg-[var(--bg-secondary)] border border-[var(--border-subtle)] space-y-2 mt-1">
                                        <input @bind="_newChapTitle" placeholder="Chapter Title"
                                               class="cyber-input text-xs w-full" />
                                        <div class="flex justify-end gap-1.5 text-[10px]">
                                            <button @onclick="CancelAddChapter" class="text-cyber-caption hover:text-[var(--accent-primary)] text-[10px]">[ CANCEL ]</button>
                                            <button @onclick="() => CreateChapterAsync(ms.ManuscriptId)" class="cyber-button text-[10px] py-0.5 px-2">[ CREATE ]</button>
                                        </div>
                                    </div>
                                }

                                @if (ms.Chapters == null || ms.Chapters.Count == 0)
                                {
                                    <p class="text-cyber-tech-mono text-[10px] text-[var(--text-disabled)] italic py-1">NO_CHAPTERS</p>
                                }
                                else
                                {
                                    @foreach (var chap in ms.Chapters)
                                    {
                                        var isSelected = _selectedChapter?.ChapterId == chap.ChapterId;
                                        <div class="flex items-center justify-between group/chap p-1 hover:bg-[var(--bg-secondary)] cursor-pointer
                                                    @(isSelected ? "bg-[var(--accent-glow)] border-l-2 border-[var(--accent-primary)] pl-1.5" : "")"
                                             @onclick="() => SelectChapter(chap, ms.ManuscriptId)">
                                            <span class="truncate flex-1 text-xs @(isSelected ? "text-[var(--accent-primary)] font-mono" : "text-[var(--text-secondary)]")">
                                                @chap.Title
                                            </span>
                                            <button @onclick="() => DeleteChapterAsync(ms.ManuscriptId, chap.ChapterId)" @onclick:stopPropagation="true"
                                                    class="opacity-0 group-hover/chap:opacity-100 text-[10px] text-[var(--accent-warning)] hover:underline">
                                                [ X ]
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Right Panel: Chapter Content Editor -->
    <div class="lg:col-span-2 p-4 bg-[var(--bg-secondary)] border border-[var(--border-subtle)] flex flex-col h-full">
        @if (_selectedChapter == null)
        {
            <div class="flex-1 flex flex-col items-center justify-center text-center">
                <span class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] mb-2">[ NO_SELECTION ]</span>
                <h3 class="text-cyber-title text-[var(--text-disabled)] uppercase mb-2">No Chapter Selected</h3>
                <p class="text-cyber-body text-xs max-w-sm">
                    Select a chapter node from the operational registry or initialize a new manuscript stream.
                </p>
            </div>
        }
        else
        {
            <!-- Editor Title & Meta -->
            <div class="flex items-center justify-between border-b border-[var(--border-subtle)] pb-3 mb-3 shrink-0">
                <div class="flex-1 max-w-lg pr-4">
                    <input @bind="_selectedChapter.Title" @oninput="TriggerAutoSave"
                           class="w-full bg-[var(--bg-primary)] text-cyber-title uppercase border border-[var(--border-subtle)] focus:border-[var(--accent-primary)] focus:outline-none px-3 py-1.5"
                           placeholder="Untitled Chapter" />
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <!-- Auto-save state message -->
                    <span class="text-[10px] font-mono uppercase tracking-wider transition-colors
                                 @(_saveStatus == "Saving..." ? "text-[var(--accent-warning)] animate-pulse" : _saveStatus == "Saved" ? "text-[var(--accent-primary)]" : "text-[var(--text-disabled)]")">
                        @_saveStatus
                    </span>
                    <!-- Version history button -->
                    <button @onclick="OpenVersionHistory" 
                            class="cyber-button text-xs py-1 px-3">
                        [ HISTORY ]
                    </button>
                    <!-- View toggle -->
                    <button @onclick="TogglePreview" 
                            class="cyber-button text-xs py-1 px-3">
                        @(_previewMode ? "[ EDIT ]" : "[ PREVIEW ]")
                    </button>
                </div>
            </div>

            <!-- Content Area -->
            <div class="flex-1 overflow-hidden relative">
                @if (_previewMode)
                {
                    <div class="w-full h-full p-4 overflow-y-auto bg-[var(--bg-primary)] border border-[var(--border-subtle)] text-cyber-body select-text">
                        <h1 class="text-cyber-title text-[var(--accent-primary)] uppercase border-b border-[var(--border-subtle)] pb-1 mb-3">@_selectedChapter.Title</h1>
                        <div class="leading-relaxed whitespace-pre-wrap font-sans text-[var(--text-secondary)] text-sm">
                            @RenderSimpleMarkdown(_selectedChapter.Content)
                        </div>
                    </div>
                }
                else
                {
                    <textarea @bind="_selectedChapter.Content" @oninput="TriggerAutoSave"
                              class="w-full h-full p-4 bg-[var(--bg-primary)] border border-[var(--border-subtle)] text-cyber-body focus:outline-none focus:border-[var(--accent-primary)] resize-none font-mono text-sm leading-relaxed"
                              placeholder="Type contents here... Supports plain text raw input."></textarea>
                }
            </div>
        }
    </div>
</div>

@if (_selectedChapter != null)
{
    <VersionHistoryModal ProjectId="ProjectId"
                         ManuscriptId="@_activeManuscriptId"
                         ChapterId="@_selectedChapter.ChapterId"
                         CurrentContent="@_selectedChapter.Content"
                         @bind-IsOpen="_versionHistoryOpen"
                         OnVersionRestored="HandleVersionRestored" />
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private List<Manuscript>? _manuscripts;
    private bool _loading = true;

    // Sidebar tree states
    private readonly HashSet<string> _expandedMs = new();
    private bool _showAddMsForm = false;
    private string _newMsTitle = string.Empty;
    private string _addingChapterMsId = string.Empty;
    private string _newChapTitle = string.Empty;

    // Selected state
    private Chapter? _selectedChapter;
    private string _activeManuscriptId = string.Empty;

    // Editor states
    private bool _previewMode = false;
    private string _saveStatus = "All changes saved";
    private CancellationTokenSource? _cts;
    private bool _versionHistoryOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadManuscriptsAsync();
    }

    private async Task LoadManuscriptsAsync()
    {
        _loading = true;
        try
        {
            var list = await ManuscriptService.GetManuscriptsByProjectAsync(ProjectId);
            _manuscripts = list ?? new List<Manuscript>();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleMsExpansion(string msId)
    {
        if (_expandedMs.Contains(msId))
            _expandedMs.Remove(msId);
        else
            _expandedMs.Add(msId);
    }

    private void ToggleAddManuscriptForm()
    {
        _showAddMsForm = !_showAddMsForm;
        _newMsTitle = string.Empty;
    }

    private async Task CreateManuscriptAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMsTitle)) return;
        var order = (_manuscripts?.Count ?? 0) + 1;
        var created = await ManuscriptService.CreateManuscriptAsync(ProjectId, _newMsTitle, order);
        if (created != null)
        {
            _expandedMs.Add(created.ManuscriptId);
            await LoadManuscriptsAsync();
            ToggleAddManuscriptForm();
        }
    }

    private async Task DeleteManuscriptAsync(string msId)
    {
        var confirmed = await Task.FromResult(true); // Simplified confirmation
        if (confirmed)
        {
            var success = await ManuscriptService.DeleteManuscriptAsync(ProjectId, msId);
            if (success)
            {
                if (_activeManuscriptId == msId)
                {
                    _selectedChapter = null;
                }
                await LoadManuscriptsAsync();
            }
        }
    }

    private void ShowAddChapterForm(string msId)
    {
        _addingChapterMsId = msId;
        _newChapTitle = string.Empty;
        _expandedMs.Add(msId);
    }

    private void CancelAddChapter()
    {
        _addingChapterMsId = string.Empty;
        _newChapTitle = string.Empty;
    }

    private async Task CreateChapterAsync(string msId)
    {
        if (string.IsNullOrWhiteSpace(_newChapTitle)) return;
        var targetMs = _manuscripts?.Find(m => m.ManuscriptId == msId);
        var order = (targetMs?.Chapters?.Count ?? 0) + 1;

        var created = await ManuscriptService.CreateChapterAsync(ProjectId, msId, _newChapTitle, "Start writing...", order);
        if (created != null)
        {
            await LoadManuscriptsAsync();
            CancelAddChapter();
            _selectedChapter = created;
            _activeManuscriptId = msId;
            _previewMode = false;
            _saveStatus = "Saved";
        }
    }

    private async Task DeleteChapterAsync(string msId, Guid chapterId)
    {
        var success = await ManuscriptService.DeleteChapterAsync(ProjectId, msId, chapterId);
        if (success)
        {
            if (_selectedChapter?.ChapterId == chapterId)
            {
                _selectedChapter = null;
            }
            await LoadManuscriptsAsync();
        }
    }

    private void SelectChapter(Chapter chap, string msId)
    {
        // Cancel any pending auto-saves first
        _cts?.Cancel();
        _cts = null;

        _selectedChapter = chap;
        _activeManuscriptId = msId;
        _previewMode = false;
        _saveStatus = "All changes saved";
    }

    private void TogglePreview()
    {
        _previewMode = !_previewMode;
    }

    private void OpenVersionHistory()
    {
        _versionHistoryOpen = true;
    }

    private void HandleVersionRestored(string restoredContent)
    {
        if (_selectedChapter != null)
        {
            _selectedChapter.Content = restoredContent;
            TriggerAutoSave();
        }
    }

    private void TriggerAutoSave(ChangeEventArgs? e = null)
    {
        _saveStatus = "Saving...";
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(1500, token);
                if (token.IsCancellationRequested) return;

                if (_selectedChapter != null)
                {
                    var updated = await ManuscriptService.UpdateChapterAsync(
                        ProjectId,
                        _activeManuscriptId,
                        _selectedChapter.ChapterId,
                        _selectedChapter.Title,
                        _selectedChapter.Content,
                        _selectedChapter.Order,
                        DateTime.UtcNow
                    );

                    if (updated != null && !token.IsCancellationRequested)
                    {
                        _saveStatus = "Saved";
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (Exception)
            {
                if (!token.IsCancellationRequested)
                {
                    _saveStatus = "All changes saved";
                    await InvokeAsync(StateHasChanged);
                }
            }
        }, token);
    }

    private MarkupString RenderSimpleMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return new MarkupString("<i>Empty chapter.</i>");
        
        // Simple secure local conversion to avoid heavy packages and keep runtime lightweight
        var safeHtml = markdown
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;");

        // Convert common markdown elements
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"^# (.*)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"^## (.*)$", "<h4>$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"\*\*(.*?)\*\*", "<strong>$1</strong>");
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"\*(.*?)\*", "<em>$1</em>");
        
        return new MarkupString(safeHtml);
    }
}
