@using System.Threading
@using client_web.Application.Services.Manuscripts
@using client_web.Models.Worldbuilding
@using Microsoft.AspNetCore.Components.Web

@inject IManuscriptService ManuscriptService

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 h-[700px]">
    <!-- Left Panel: Tree View -->
    <div class="lg:col-span-1 p-4 bg-base-blue-3 border border-white/5 rounded-xl flex flex-col h-full overflow-hidden shadow-md">
        <div class="flex items-center justify-between border-b border-white/5 pb-3 mb-3 shrink-0">
            <h3 class="text-stone-200 text-sm font-semibold tracking-wider uppercase">Manuscripts</h3>
            <button @onclick="ToggleAddManuscriptForm" 
                    class="px-2 py-1 bg-amber-500/10 border border-amber-500/20 text-amber-300 hover:bg-amber-500/20 hover:text-amber-200 text-xs font-semibold rounded transition-all">
                + New MS
            </button>
        </div>

        @if (_showAddMsForm)
        {
            <div class="p-3 bg-white/5 rounded-lg border border-white/5 mb-3 shrink-0 space-y-2">
                <input @bind="_newMsTitle" placeholder="Manuscript Title" 
                       class="w-full px-3 py-1.5 bg-stone-900 border border-white/10 rounded text-xs text-stone-200 focus:outline-none focus:border-amber-500" />
                <div class="flex justify-end gap-2 text-xs">
                    <button @onclick="ToggleAddManuscriptForm" class="px-2 py-1 text-stone-400 hover:text-stone-200">Cancel</button>
                    <button @onclick="CreateManuscriptAsync" class="px-2 py-1 bg-amber-500 text-stone-950 font-bold rounded hover:bg-amber-400">Create</button>
                </div>
            </div>
        }

        <!-- Manuscripts Tree Container -->
        <div class="flex-1 overflow-y-auto pr-1 space-y-2 text-sm text-stone-300">
            @if (_loading)
            {
                <p class="text-stone-500 text-xs animate-pulse">Loading manuscripts...</p>
            }
            else if (_manuscripts == null || _manuscripts.Count == 0)
            {
                <p class="text-stone-500 text-xs py-4 text-center">No manuscripts created yet.</p>
            }
            else
            {
                @foreach (var ms in _manuscripts)
                {
                    var isExpanded = _expandedMs.Contains(ms.ManuscriptId);
                    <div class="border border-white/5 rounded-lg bg-stone-950/20 p-2 space-y-1">
                        <!-- Manuscript Title Block -->
                        <div class="flex items-center justify-between group">
                            <div class="flex items-center gap-2 cursor-pointer flex-1" @onclick="() => ToggleMsExpansion(ms.ManuscriptId)">
                                <span class="text-stone-500 text-xs select-none">
                                    @(isExpanded ? "▼" : "▶")
                                </span>
                                <span class="font-medium text-stone-200 truncate">@ms.Title</span>
                            </div>
                            <div class="opacity-0 group-hover:opacity-100 flex gap-2 transition-all">
                                <button @onclick="() => ShowAddChapterForm(ms.ManuscriptId)" title="Add Chapter" class="text-[10px] text-amber-500 hover:text-amber-400">
                                    + Add Chap
                                </button>
                                <button @onclick="() => DeleteManuscriptAsync(ms.ManuscriptId)" title="Delete Manuscript" class="text-[10px] text-red-500 hover:text-red-400">
                                    Delete
                                </button>
                            </div>
                        </div>

                        <!-- Chapters under this manuscript -->
                        @if (isExpanded)
                        {
                            <div class="pl-4 border-l border-white/5 mt-1 space-y-1">
                                @if (_addingChapterMsId == ms.ManuscriptId)
                                {
                                    <div class="p-2 bg-white/5 rounded space-y-2 mt-1">
                                        <input @bind="_newChapTitle" placeholder="Chapter Title"
                                               class="w-full px-2 py-1 bg-stone-900 border border-white/10 rounded text-xs text-stone-200 focus:outline-none focus:border-amber-500" />
                                        <div class="flex justify-end gap-1.5 text-[10px]">
                                            <button @onclick="CancelAddChapter" class="px-2 py-0.5 text-stone-400">Cancel</button>
                                            <button @onclick="() => CreateChapterAsync(ms.ManuscriptId)" class="px-2 py-0.5 bg-amber-500 text-stone-950 font-bold rounded">Create</button>
                                        </div>
                                    </div>
                                }

                                @if (ms.Chapters == null || ms.Chapters.Count == 0)
                                {
                                    <p class="text-stone-600 text-xs italic py-1">No chapters.</p>
                                }
                                else
                                {
                                    @foreach (var chap in ms.Chapters)
                                    {
                                        var isSelected = _selectedChapter?.ChapterId == chap.ChapterId;
                                        <div class="flex items-center justify-between group/chap p-1 rounded hover:bg-white/5 transition-colors cursor-pointer
                                                    @(isSelected ? "bg-amber-500/10 border-l-2 border-amber-500 pl-1.5" : "")"
                                             @onclick="() => SelectChapter(chap, ms.ManuscriptId)">
                                            <span class="truncate flex-1 text-xs @(isSelected ? "text-amber-400 font-semibold" : "text-stone-300")">
                                                @chap.Title
                                            </span>
                                            <button @onclick="() => DeleteChapterAsync(ms.ManuscriptId, chap.ChapterId)" @onclick:stopPropagation="true"
                                                    class="opacity-0 group-hover/chap:opacity-100 text-[10px] text-red-500 hover:text-red-400 transition-opacity">
                                                🗑
                                            </button>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    <!-- Right Panel: Chapter Content Editor -->
    <div class="lg:col-span-2 p-6 bg-base-blue-3 border border-white/5 rounded-xl flex flex-col h-full shadow-md">
        @if (_selectedChapter == null)
        {
            <div class="flex-1 flex flex-col items-center justify-center text-center">
                <span class="text-stone-600 text-5xl mb-4">✍️</span>
                <h3 class="text-stone-400 font-medium mb-1">No Chapter Selected</h3>
                <p class="text-stone-500 text-xs max-w-sm leading-relaxed">
                    Select a chapter from the sidebar tree or create a new manuscript and chapter to begin crafting your epic.
                </p>
            </div>
        }
        else
        {
            <!-- Editor Title & Meta -->
            <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-4 shrink-0">
                <div class="flex-1 max-w-lg">
                    <input @bind="_selectedChapter.Title" @oninput="TriggerAutoSave"
                           class="w-full bg-transparent text-xl font-serif text-stone-100 border-none border-b border-transparent focus:border-amber-500/30 focus:outline-none py-1 transition-all"
                           placeholder="Untitled Chapter" />
                </div>
                <div class="flex items-center gap-4 shrink-0">
                    <!-- Auto-save state message -->
                    <span class="text-[10px] uppercase font-semibold tracking-wider transition-colors
                                 @(_saveStatus == "Saving..." ? "text-amber-400 animate-pulse" : _saveStatus == "Saved" ? "text-emerald-500" : "text-stone-500")">
                        @_saveStatus
                    </span>
                    <!-- View toggle -->
                    <button @onclick="TogglePreview" 
                            class="px-3 py-1 border border-white/10 rounded text-xs text-stone-300 hover:bg-white/5 hover:text-stone-100 font-semibold tracking-wider uppercase transition-all">
                        @(_previewMode ? "Edit Page" : "Preview Page")
                    </button>
                </div>
            </div>

            <!-- Content Area -->
            <div class="flex-1 overflow-hidden relative">
                @if (_previewMode)
                {
                    <div class="w-full h-full p-4 overflow-y-auto rounded-lg bg-stone-950/20 border border-white/5 prose prose-invert max-w-none text-stone-200 select-text">
                        <h1 class="font-serif text-2xl text-amber-500 font-light border-b border-white/5 pb-2 mb-4">@_selectedChapter.Title</h1>
                        <div class="leading-relaxed whitespace-pre-wrap font-serif text-stone-300">
                            @RenderSimpleMarkdown(_selectedChapter.Content)
                        </div>
                    </div>
                }
                else
                {
                    <textarea @bind="_selectedChapter.Content" @oninput="TriggerAutoSave"
                              class="w-full h-full p-6 bg-stone-950/20 border border-white/5 rounded-lg text-stone-200 focus:outline-none focus:border-amber-500/20 resize-none font-serif text-base leading-relaxed leading-8"
                              placeholder="Write your story here... Supports plain text writing."></textarea>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private List<Manuscript>? _manuscripts;
    private bool _loading = true;

    // Sidebar tree states
    private readonly HashSet<string> _expandedMs = new();
    private bool _showAddMsForm = false;
    private string _newMsTitle = string.Empty;
    private string _addingChapterMsId = string.Empty;
    private string _newChapTitle = string.Empty;

    // Selected state
    private Chapter? _selectedChapter;
    private string _activeManuscriptId = string.Empty;

    // Editor states
    private bool _previewMode = false;
    private string _saveStatus = "All changes saved";
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        await LoadManuscriptsAsync();
    }

    private async Task LoadManuscriptsAsync()
    {
        _loading = true;
        try
        {
            var list = await ManuscriptService.GetManuscriptsByProjectAsync(ProjectId);
            _manuscripts = list ?? new List<Manuscript>();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleMsExpansion(string msId)
    {
        if (_expandedMs.Contains(msId))
            _expandedMs.Remove(msId);
        else
            _expandedMs.Add(msId);
    }

    private void ToggleAddManuscriptForm()
    {
        _showAddMsForm = !_showAddMsForm;
        _newMsTitle = string.Empty;
    }

    private async Task CreateManuscriptAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMsTitle)) return;
        var order = (_manuscripts?.Count ?? 0) + 1;
        var created = await ManuscriptService.CreateManuscriptAsync(ProjectId, _newMsTitle, order);
        if (created != null)
        {
            _expandedMs.Add(created.ManuscriptId);
            await LoadManuscriptsAsync();
            ToggleAddManuscriptForm();
        }
    }

    private async Task DeleteManuscriptAsync(string msId)
    {
        var confirmed = await Task.FromResult(true); // Simplified confirmation
        if (confirmed)
        {
            var success = await ManuscriptService.DeleteManuscriptAsync(ProjectId, msId);
            if (success)
            {
                if (_activeManuscriptId == msId)
                {
                    _selectedChapter = null;
                }
                await LoadManuscriptsAsync();
            }
        }
    }

    private void ShowAddChapterForm(string msId)
    {
        _addingChapterMsId = msId;
        _newChapTitle = string.Empty;
        _expandedMs.Add(msId);
    }

    private void CancelAddChapter()
    {
        _addingChapterMsId = string.Empty;
        _newChapTitle = string.Empty;
    }

    private async Task CreateChapterAsync(string msId)
    {
        if (string.IsNullOrWhiteSpace(_newChapTitle)) return;
        var targetMs = _manuscripts?.Find(m => m.ManuscriptId == msId);
        var order = (targetMs?.Chapters?.Count ?? 0) + 1;

        var created = await ManuscriptService.CreateChapterAsync(ProjectId, msId, _newChapTitle, "Start writing...", order);
        if (created != null)
        {
            await LoadManuscriptsAsync();
            CancelAddChapter();
            _selectedChapter = created;
            _activeManuscriptId = msId;
            _previewMode = false;
            _saveStatus = "Saved";
        }
    }

    private async Task DeleteChapterAsync(string msId, Guid chapterId)
    {
        var success = await ManuscriptService.DeleteChapterAsync(ProjectId, msId, chapterId);
        if (success)
        {
            if (_selectedChapter?.ChapterId == chapterId)
            {
                _selectedChapter = null;
            }
            await LoadManuscriptsAsync();
        }
    }

    private void SelectChapter(Chapter chap, string msId)
    {
        // Cancel any pending auto-saves first
        _cts?.Cancel();
        _cts = null;

        _selectedChapter = chap;
        _activeManuscriptId = msId;
        _previewMode = false;
        _saveStatus = "All changes saved";
    }

    private void TogglePreview()
    {
        _previewMode = !_previewMode;
    }

    private void TriggerAutoSave(ChangeEventArgs e)
    {
        _saveStatus = "Saving...";
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(1500, token);
                if (token.IsCancellationRequested) return;

                if (_selectedChapter != null)
                {
                    var updated = await ManuscriptService.UpdateChapterAsync(
                        ProjectId,
                        _activeManuscriptId,
                        _selectedChapter.ChapterId,
                        _selectedChapter.Title,
                        _selectedChapter.Content,
                        _selectedChapter.Order,
                        DateTime.UtcNow
                    );

                    if (updated != null && !token.IsCancellationRequested)
                    {
                        _saveStatus = "Saved";
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (Exception)
            {
                if (!token.IsCancellationRequested)
                {
                    _saveStatus = "All changes saved";
                    await InvokeAsync(StateHasChanged);
                }
            }
        }, token);
    }

    private MarkupString RenderSimpleMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown)) return new MarkupString("<i>Empty chapter.</i>");
        
        // Simple secure local conversion to avoid heavy packages and keep runtime lightweight
        var safeHtml = markdown
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;");

        // Convert common markdown elements
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"^# (.*)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"^## (.*)$", "<h4>$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"\*\*(.*?)\*\*", "<strong>$1</strong>");
        safeHtml = System.Text.RegularExpressions.Regex.Replace(safeHtml, @"\*(.*?)\*", "<em>$1</em>");
        
        return new MarkupString(safeHtml);
    }
}
