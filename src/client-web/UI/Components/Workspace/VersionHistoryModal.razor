@using client_web.Application.Services.Manuscripts
@using Layla.Client.Shared.Models
@inject IManuscriptService ManuscriptService

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
        <!-- Backdrop -->
        <div @onclick="CloseModal" class="absolute inset-0 bg-black/70"></div>

        <!-- Modal Container -->
        <div class="cyber-panel w-full max-w-5xl h-[85vh] flex flex-col relative z-10 overflow-hidden p-0 bg-base-gray-1 border-base-gray-4">
            <!-- Header -->
            <div class="cyber-panel-header px-6 py-4 shrink-0 pb-3 mb-0 border-b border-base-gray-4">
                <div>
                    <h3 class="text-cyber-title text-sm tracking-wide uppercase">Historial de Versiones</h3>
                    <p class="text-cyber-metadata text-[10px] uppercase tracking-wider font-semibold">Compara guardados y restaura tu manuscrito</p>
                </div>
                <button @onclick="CloseModal" class="text-cyber-metadata hover:text-cyber-tech-mono p-1">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <!-- Body (Split Layout) -->
            <div class="flex-1 flex overflow-hidden">
                <!-- Left Sidebar: Timeline -->
                <div class="w-80 border-r border-base-gray-4 overflow-y-auto p-4 space-y-4 bg-base-gray-2">
                    <h4 class="text-[10px] text-cyber-metadata font-semibold px-2">Línea de Tiempo</h4>
                    
                    @if (_loadingVersions)
                    {
                        <div class="flex flex-col items-center justify-center py-12 space-y-3">
                            <span class="text-cyber-tech-mono animate-pulse text-xs">// LOADING_TIMELINE</span>
                        </div>
                    }
                    else if (_versions.Count == 0)
                    {
                        <p class="text-cyber-metadata text-xs italic text-center py-8">No hay versiones registradas.</p>
                    }
                    else
                    {
                        <div class="relative pl-4 border-l border-base-gray-4 space-y-3">
                            @foreach (var v in _versions)
                            {
                                var isSelected = _selectedVersionId == v.Id;
                                <button @onclick="() => SelectVersionAsync(v.Id)"
                                        class="w-full text-left p-3 border relative outline-none flex flex-col gap-1.5 transition-none
                                               @(isSelected ? "bg-base-gray-3 border-[var(--accent-primary)] text-[var(--accent-primary)]" : "bg-base-gray-1 border-base-gray-4 hover:border-base-gray-5 text-cyber-caption")">
                                    
                                    <!-- Bullet indicator: square anchor -->
                                    <span class="absolute -left-[21px] top-4.5 w-2 h-2 border border-base-gray-1 
                                                 @(isSelected ? "bg-[var(--accent-primary)]" : "bg-base-gray-5")"></span>

                                    <div class="flex justify-between items-center w-full">
                                        <span class="text-[10px] font-mono uppercase font-bold">
                                            @(v.IsMilestone ? "Hito" : "Autoguardado")
                                        </span>
                                        <span class="text-[9px] text-cyber-metadata">
                                            @v.CreatedAt.ToString("HH:mm:ss")
                                        </span>
                                    </div>
                                    <div class="text-[11px] font-mono truncate">
                                        Por: @v.CreatedBy
                                    </div>
                                    <div class="text-[9px] text-cyber-metadata">
                                        @v.CreatedAt.ToString("dd/MM/yyyy")
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>

                <!-- Right Area: Diff/Preview -->
                <div class="flex-1 flex flex-col overflow-hidden bg-base-gray-1">
                    @if (string.IsNullOrEmpty(_selectedVersionId))
                    {
                        <div class="flex-1 flex flex-col items-center justify-center p-8 text-center space-y-2">
                            <span class="text-cyber-tech-mono text-xs uppercase text-cyber-metadata">// SELECT_A_SAVED_VERSION_TO_COMPARE</span>
                        </div>
                    }
                    else if (_loadingVersionContent)
                    {
                        <div class="flex-1 flex flex-col items-center justify-center space-y-3">
                            <span class="text-cyber-tech-mono animate-pulse text-xs">// CALCULATING_DIFF...</span>
                        </div>
                    }
                    else
                    {
                        <!-- Diff Content Area -->
                        <div class="flex-1 overflow-y-auto p-8 font-mono leading-relaxed text-sm text-cyber-body whitespace-pre-wrap select-text">
                            @if (_diffPieces.Count == 0)
                            {
                                <span class="text-cyber-metadata">// No hay cambios o el documento está vacío.</span>
                            }
                            else
                            {
                                @foreach (var piece in _diffPieces)
                                {
                                    @if (piece.Type == DiffType.Unchanged)
                                    {
                                        <span>@piece.Text</span>
                                    }
                                    else if (piece.Type == DiffType.Inserted)
                                    {
                                        <span class="bg-[var(--accent-glow)] text-[var(--accent-primary)] px-0.5 border border-[var(--accent-primary)]/20 font-bold">@piece.Text</span>
                                    }
                                    else if (piece.Type == DiffType.Deleted)
                                    {
                                        <span class="bg-base-orange-1/5 text-[var(--accent-warning)] line-through px-0.5 border border-base-orange-1/20 opacity-70">@piece.Text</span>
                                    }
                                }
                            }
                        </div>

                        <!-- Footer Actions -->
                        <div class="h-16 px-8 border-t border-base-gray-4 flex items-center justify-between shrink-0 bg-base-gray-2">
                            <div class="flex items-center gap-4 text-xs">
                                <div class="flex items-center gap-1.5 font-mono text-cyber-metadata">
                                    <span class="w-2 h-2 bg-[var(--accent-glow)] border border-[var(--accent-primary)]/40"></span>
                                    <span>Adición (Cyan)</span>
                                </div>
                                <div class="flex items-center gap-1.5 font-mono text-cyber-metadata">
                                    <span class="w-2 h-2 bg-base-orange-1/5 border border-base-orange-1/30 line-through"></span>
                                    <span>Eliminación (Ámbar)</span>
                                </div>
                            </div>

                            <button @onclick="RestoreVersionAsync" disabled="@_restoring" class="cyber-button text-xs py-2 px-5">
                                @(_restoring ? "Restaurando..." : "Restaurar esta Versión")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public string ManuscriptId { get; set; } = string.Empty;
    [Parameter] public Guid ChapterId { get; set; }
    [Parameter] public string CurrentContent { get; set; } = string.Empty;
    
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<string> OnVersionRestored { get; set; }

    private List<ChapterVersionMeta> _versions = new();
    private bool _loadingVersions = false;
    
    private string _selectedVersionId = string.Empty;
    private ChapterVersionFull? _selectedVersion;
    private bool _loadingVersionContent = false;
    private bool _restoring = false;

    private List<DiffPiece> _diffPieces = new();

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _versions.Count == 0 && !_loadingVersions)
        {
            await LoadVersionsAsync();
        }
    }

    private async Task LoadVersionsAsync()
    {
        _loadingVersions = true;
        _selectedVersionId = string.Empty;
        _selectedVersion = null;
        _diffPieces.Clear();
        StateHasChanged();

        try
        {
            var res = await ManuscriptService.GetChapterVersionsAsync(ProjectId, ManuscriptId, ChapterId);
            _versions = res?.OrderByDescending(v => v.CreatedAt).ToList() ?? new List<ChapterVersionMeta>();
        }
        catch
        {
            _versions.Clear();
        }
        finally
        {
            _loadingVersions = false;
            StateHasChanged();
        }
    }

    private async Task SelectVersionAsync(string versionId)
    {
        _selectedVersionId = versionId;
        _loadingVersionContent = true;
        _diffPieces.Clear();
        StateHasChanged();

        try
        {
            _selectedVersion = await ManuscriptService.GetChapterVersionAsync(ProjectId, ManuscriptId, ChapterId, versionId);
            if (_selectedVersion != null)
            {
                // Calculate word diff between historic version and current live text
                _diffPieces = DiffCalculator.CalculateDiff(_selectedVersion.Content, CurrentContent);
            }
        }
        catch
        {
            _selectedVersion = null;
        }
        finally
        {
            _loadingVersionContent = false;
            StateHasChanged();
        }
    }

    private async Task RestoreVersionAsync()
    {
        if (string.IsNullOrEmpty(_selectedVersionId) || _selectedVersion == null) return;

        _restoring = true;
        StateHasChanged();

        try
        {
            var ok = await ManuscriptService.RestoreChapterVersionAsync(ProjectId, ManuscriptId, ChapterId, _selectedVersionId);
            if (ok)
            {
                await OnVersionRestored.InvokeAsync(_selectedVersion.Content);
                await CloseModal();
            }
        }
        finally
        {
            _restoring = false;
            StateHasChanged();
        }
    }

    private async Task CloseModal()
    {
        _versions.Clear();
        _selectedVersionId = string.Empty;
        _selectedVersion = null;
        _diffPieces.Clear();
        
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(IsOpen);
    }

    // Dynamic Programming LCS Diff Engine in Pure C#
    public enum DiffType { Unchanged, Inserted, Deleted }
    public record DiffPiece(string Text, DiffType Type);

    public static class DiffCalculator
    {
        public static List<DiffPiece> CalculateDiff(string oldText, string newText)
        {
            // Standardize text splits by words + space keeping
            var oldWords = SplitWords(oldText ?? string.Empty);
            var newWords = SplitWords(newText ?? string.Empty);

            int n = oldWords.Count;
            int m = newWords.Count;
            int[,] dp = new int[n + 1, m + 1];

            // DP LCS calculation
            for (int i = 1; i <= n; i++)
            {
                for (int j = 1; j <= m; j++)
                {
                    if (oldWords[i - 1] == newWords[j - 1])
                        dp[i, j] = dp[i - 1, j - 1] + 1;
                    else
                        dp[i, j] = Math.Max(dp[i - 1, j], dp[i, j - 1]);
                }
            }

            var result = new List<DiffPiece>();
            int x = n, y = m;

            // Backtrack DP matrix
            while (x > 0 || y > 0)
            {
                if (x > 0 && y > 0 && oldWords[x - 1] == newWords[y - 1])
                {
                    result.Add(new DiffPiece(oldWords[x - 1], DiffType.Unchanged));
                    x--;
                    y--;
                }
                else if (y > 0 && (x == 0 || dp[x, y - 1] >= dp[x - 1, y]))
                {
                    result.Add(new DiffPiece(newWords[y - 1], DiffType.Inserted));
                    y--;
                }
                else
                {
                    result.Add(new DiffPiece(oldWords[x - 1], DiffType.Deleted));
                    x--;
                }
            }

            result.Reverse();
            return result;
        }

        private static List<string> SplitWords(string text)
        {
            var words = new List<string>();
            var currentWord = new System.Text.StringBuilder();

            foreach (var c in text)
            {
                if (char.IsWhiteSpace(c) || char.IsPunctuation(c))
                {
                    if (currentWord.Length > 0)
                    {
                        words.Add(currentWord.ToString());
                        currentWord.Clear();
                    }
                    words.Add(c.ToString());
                }
                else
                {
                    currentWord.Append(c);
                }
            }

            if (currentWord.Length > 0)
            {
                words.Add(currentWord.ToString());
            }

            return words;
        }
    }
}
