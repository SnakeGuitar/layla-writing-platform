@using Microsoft.AspNetCore.SignalR.Client
@using client_web.Application.Config.SignalR
@using client_web.Application.Services.Voice
@using client_web.Application.Services.Session
@inject IVoiceService VoiceService
@inject ISessionManager SessionManager
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="fixed inset-y-0 right-0 w-80 bg-stone-950/95 border-l border-white/10 shadow-2xl backdrop-blur-xl z-40 flex flex-col transition-transform duration-300 transform @(IsOpen ? "translate-x-0" : "translate-x-full")">
    
    <!-- Header -->
    <div class="h-16 px-6 border-b border-white/5 flex items-center justify-between shrink-0">
        <div class="flex items-center gap-3">
            <h3 class="text-stone-100 font-semibold tracking-wide text-sm">Sala de Voz</h3>
            <span class="w-2.5 h-2.5 rounded-full @StatusColor animate-pulse"></span>
        </div>
        <button @onclick="CloseDrawerAsync" class="text-stone-500 hover:text-stone-200 p-1.5 rounded-lg hover:bg-white/5 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    <!-- Scrollable content -->
    <div class="flex-1 overflow-y-auto p-6 space-y-6">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="p-3 bg-red-950/20 border border-red-900/50 rounded-lg text-red-400 text-xs">
                @_error
            </div>
        }

        @if (!VoiceService.IsConnected)
        {
            <div class="space-y-4 text-center py-8">
                <div class="mx-auto w-12 h-12 bg-white/5 rounded-full flex items-center justify-center text-stone-400">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                    </svg>
                </div>
                <div>
                    <h4 class="text-stone-200 text-sm font-medium">Reunirse por Voz</h4>
                    <p class="text-stone-500 text-xs mt-1">Conéctate para hablar con tus colaboradores en tiempo real.</p>
                </div>
                <button @onclick="ConnectAsync" disabled="@_isConnecting"
                        class="w-full py-2 bg-amber-500 hover:bg-amber-600 disabled:bg-stone-800 text-stone-950 disabled:text-stone-600 rounded-lg text-xs font-semibold uppercase tracking-wider transition-colors">
                    @(_isConnecting ? "Conectando..." : "Unirse a la llamada")
                </button>
            </div>
        }
        else
        {
            <!-- Call state -->
            <div class="space-y-4">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] text-stone-500 uppercase tracking-wider font-semibold">Participantes (@_participants.Count)</span>
                    <button @onclick="LeaveRoomAsync" class="text-xs text-red-400 hover:text-red-300 font-medium transition-colors">
                        Abandonar
                    </button>
                </div>

                <!-- Participants list -->
                <div class="space-y-2 max-h-60 overflow-y-auto pr-1">
                    @if (_participants.Count == 0)
                    {
                        <p class="text-stone-600 text-xs italic text-center py-4">Nadie en la sala</p>
                    }
                    else
                    {
                        @foreach (var p in _participants)
                        {
                            <div class="flex items-center justify-between p-2.5 bg-stone-900/50 border border-white/5 rounded-lg">
                                <div class="flex items-center gap-3">
                                    <div class="relative">
                                        <div class="w-8 h-8 rounded-full bg-stone-800 border border-white/10 flex items-center justify-center text-stone-300 text-xs font-bold font-serif uppercase">
                                            @p.DisplayName.Substring(0, Math.Min(2, p.DisplayName.Length))
                                        </div>
                                        <span class="absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border-2 border-stone-950 @(p.IsSpeaking ? "bg-emerald-400" : "bg-stone-500")"></span>
                                    </div>
                                    <div>
                                        <div class="text-xs text-stone-200 font-medium">@p.DisplayName</div>
                                        <div class="text-[9px] text-stone-500">
                                            @(p.Role == "Reader" ? "Oyente" : "Colaborador")
                                        </div>
                                    </div>
                                </div>

                                @if (p.IsSpeaking)
                                {
                                    <span class="flex gap-0.5 items-end h-3">
                                        <span class="w-0.5 bg-emerald-400 animate-[bounce_0.8s_infinite_100ms] h-full"></span>
                                        <span class="w-0.5 bg-emerald-400 animate-[bounce_0.8s_infinite_200ms] h-2"></span>
                                        <span class="w-0.5 bg-emerald-400 animate-[bounce_0.8s_infinite_300ms] h-full"></span>
                                    </span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>

    <!-- PTT Area (Sticky at bottom) -->
    @if (VoiceService.IsConnected)
    {
        <div class="p-6 border-t border-white/5 bg-stone-950/80 backdrop-blur-md flex flex-col items-center justify-center space-y-3 shrink-0 select-none">
            <button @onmousedown="StartSpeakingAsync" 
                    @onmouseup="StopSpeakingAsync" 
                    @ontouchstart="StartSpeakingAsync"
                    @ontouchend="StopSpeakingAsync" 
                    class="w-28 h-28 rounded-full text-stone-100 font-bold text-lg flex flex-col items-center justify-center shadow-xl border transition-all duration-200 transform outline-none select-none
                           @(_isSpeaking ? "bg-red-600 scale-105 border-red-500 shadow-red-600/30" : "bg-amber-500/10 hover:bg-amber-500 hover:text-stone-950 border-amber-500/30 hover:border-amber-500")">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 mb-1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                </svg>
                <span class="text-[10px] font-semibold uppercase tracking-wider">
                    @(_isSpeaking ? "Hablando..." : "Mantener PTT")
                </span>
            </button>
            <span class="text-[9px] text-stone-500">
                @(_isSpeaking ? "Suelta para silenciar" : "Mantén presionado para hablar")
            </span>
        </div>
    }
</div>

<!-- Backdrop (closes drawer on click) -->
@if (IsOpen)
{
    <div @onclick="CloseDrawerAsync" class="fixed inset-0 bg-black/40 z-30 transition-opacity"></div>
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }

    private bool _isConnecting = false;
    private bool _isSpeaking = false;
    private string? _error;
    private List<VoiceParticipant> _participants = new();
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<VoiceDrawer>? _dotNetRef;

    private string StatusColor => VoiceService.State switch
    {
        HubConnectionState.Connected => "bg-emerald-400",
        HubConnectionState.Connecting => "bg-amber-400",
        HubConnectionState.Reconnecting => "bg-orange-400",
        _ => "bg-stone-500"
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                identifier: "import",
                args: "./js/voiceAudio.js"
            );
        }
    }

    private async Task CloseDrawerAsync()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(IsOpen);
    }

    private async Task ConnectAsync()
    {
        _isConnecting = true;
        _error = null;
        StateHasChanged();

        try
        {
            await SessionManager.InitializeAsync();
            var token = SessionManager.CurrentToken;
            if (string.IsNullOrEmpty(token))
            {
                _error = "Es necesario iniciar sesión.";
                return;
            }

            VoiceService.OnRoomStateChanged += OnRoomState;
            VoiceService.OnUserJoined += OnUserJoined;
            VoiceService.OnUserLeft += OnUserLeft;
            VoiceService.OnSpeakerStarted += OnSpeakerStarted;
            VoiceService.OnSpeakerStopped += OnSpeakerStopped;
            VoiceService.OnAudioReceived += OnAudioReceived;
            VoiceService.OnConnectionChanged += OnConnectionChanged;

            await VoiceService.ConnectAsync(token);
            await VoiceService.JoinRoomAsync(ProjectId);

            if (_jsModule != null)
                await _jsModule.InvokeVoidAsync("initPlayback");
        }
        catch (Exception ex)
        {
            _error = $"Error al unirse: {ex.Message}";
            await LeaveRoomAsync();
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    private async Task StartSpeakingAsync()
    {
        if (!VoiceService.IsConnected) return;
        try
        {
            await VoiceService.StartSpeakingAsync(ProjectId);
            _isSpeaking = true;

            if (_jsModule != null)
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await _jsModule.InvokeVoidAsync("startCapture", _dotNetRef);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        StateHasChanged();
    }

    private async Task StopSpeakingAsync()
    {
        if (!_isSpeaking) return;
        _isSpeaking = false;

        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("stopCapture");

        await VoiceService.StopSpeakingAsync(ProjectId);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnAudioCaptured(string base64Audio)
    {
        byte[] audioData = Convert.FromBase64String(base64Audio);
        await VoiceService.SendAudioAsync(ProjectId, audioData);
    }

    private async Task LeaveRoomAsync()
    {
        if (_isSpeaking)
            await StopSpeakingAsync();

        try
        {
            await VoiceService.LeaveRoomAsync(ProjectId);
            await VoiceService.DisconnectAsync();
        }
        catch { }

        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("disposePlayback");

        _participants.Clear();
        UnsubscribeEvents();
        StateHasChanged();
    }

    private void UnsubscribeEvents()
    {
        VoiceService.OnRoomStateChanged -= OnRoomState;
        VoiceService.OnUserJoined -= OnUserJoined;
        VoiceService.OnUserLeft -= OnUserLeft;
        VoiceService.OnSpeakerStarted -= OnSpeakerStarted;
        VoiceService.OnSpeakerStopped -= OnSpeakerStopped;
        VoiceService.OnAudioReceived -= OnAudioReceived;
        VoiceService.OnConnectionChanged -= OnConnectionChanged;
    }

    private void OnRoomState(object? sender, List<VoiceParticipant> participants)
    {
        _participants = participants;
        InvokeAsync(StateHasChanged);
    }

    private void OnUserJoined(object? sender, VoiceParticipant participant)
    {
        if (_participants.All(p => p.UserId != participant.UserId))
            _participants.Add(participant);
        InvokeAsync(StateHasChanged);
    }

    private void OnUserLeft(object? sender, string userId)
    {
        _participants.RemoveAll(p => p.UserId == userId);
        InvokeAsync(StateHasChanged);
    }

    private void OnSpeakerStarted(object? sender, (string userId, string displayName) e)
    {
        var idx = _participants.FindIndex(p => p.UserId == e.userId);
        if (idx >= 0)
            _participants[idx] = _participants[idx] with { IsSpeaking = true };
        InvokeAsync(StateHasChanged);
    }

    private void OnSpeakerStopped(object? sender, string userId)
    {
        int idx = _participants.FindIndex(p => p.UserId == userId);
        if (idx >= 0)
            _participants[idx] = _participants[idx] with { IsSpeaking = false };
        InvokeAsync(StateHasChanged);
    }

    private void OnAudioReceived(object? sender, (string senderId, byte[] audio) e)
    {
        if (_jsModule != null)
        {
            var base64 = Convert.ToBase64String(e.audio);
            _ = _jsModule.InvokeVoidAsync("playAudio", base64);
        }
    }

    private async void OnConnectionChanged(object? sender, HubConnectionState state)
    {
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        UnsubscribeEvents();
        _dotNetRef?.Dispose();

        if (_jsModule != null)
            await _jsModule.DisposeAsync();
    }
}
