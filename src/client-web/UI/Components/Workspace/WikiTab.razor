@using client_web.Application.Services.Wikis
@using client_web.Models.Worldbuilding
@inject IWikiService WikiService

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 h-[700px]">
    <!-- Left Column: Search, Filter, and Entries list -->
    <div class="lg:col-span-1 p-4 bg-[var(--bg-secondary)] border border-[var(--border-subtle)] flex flex-col h-full overflow-hidden">
        <!-- Search & Add Entry Button -->
        <div class="shrink-0 space-y-2 mb-4">
            <div class="flex items-center justify-between">
                <h3 class="text-cyber-tech-mono text-xs text-[var(--text-secondary)] uppercase">Wiki Entries</h3>
                <button @onclick="ShowCreateForm" 
                        class="cyber-button text-[10px] py-0.5 px-2">
                    [ + NEW ENTRY ]
                </button>
            </div>
            
            <input @bind="_searchText" @bind:event="oninput" placeholder="SEARCH ENTRIES..."
                   class="cyber-input text-xs w-full" />
            
            <!-- Type Filters -->
            <div class="flex flex-wrap gap-1">
                @foreach (var type in _entityTypes)
                {
                    var isSelected = _filterType == type;
                    <button @onclick="() => SetFilterType(type)"
                            class="px-2 py-1 text-[10px] font-mono uppercase border transition-all duration-100 steps-2
                                   @(isSelected ? "bg-[var(--accent-glow)] border-[var(--accent-primary)] text-[var(--accent-primary)]" : "bg-transparent border-[var(--border-subtle)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-active)]")">
                        @type
                    </button>
                }
            </div>
        </div>

        <!-- Create Entry Inline Form -->
        @if (_showCreateForm)
        {
            <div class="p-3 bg-[var(--bg-primary)] border border-[var(--border-subtle)] mb-4 shrink-0 space-y-2 text-xs">
                <h4 class="text-cyber-title text-xs uppercase mb-1">Create Lore Entry</h4>
                <input @bind="_newEntryName" placeholder="Entry Name (e.g. Elena Voss)" 
                       class="cyber-input text-xs w-full bg-[var(--bg-secondary)]" />
                
                <select @bind="_newEntryType" 
                        class="cyber-input text-xs w-full bg-[var(--bg-secondary)]">
                    <option value="Character">Character</option>
                    <option value="Location">Location</option>
                    <option value="Event">Event</option>
                    <option value="Object">Object</option>
                </select>

                <textarea @bind="_newEntryDescription" placeholder="Description..." rows="2"
                          class="cyber-input text-xs w-full bg-[var(--bg-secondary)] resize-none"></textarea>

                <input @bind="_newEntryTags" placeholder="Tags (comma separated: pilot, rebel)" 
                       class="cyber-input text-xs w-full bg-[var(--bg-secondary)]" />

                <div class="flex justify-end gap-2">
                    <button @onclick="CancelCreateForm" class="text-cyber-caption hover:text-[var(--accent-primary)] text-[10px]">[ CANCEL ]</button>
                    <button @onclick="CreateEntryAsync" class="cyber-button text-[10px] py-0.5 px-2">[ SAVE ]</button>
                </div>
            </div>
        }

        <!-- Entries List -->
        <div class="flex-1 overflow-y-auto pr-1 space-y-2">
            @if (_loading)
            {
                <p class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] animate-pulse">LOADING LORE ENTRIES...</p>
            }
            else
            {
                var filtered = GetFilteredEntries();
                if (filtered.Count == 0)
                {
                    <p class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] text-center py-4">NO ENTRIES FOUND.</p>
                }
                else
                {
                    @foreach (var entry in filtered)
                    {
                        var isSelected = _selectedEntry?.EntityId == entry.EntityId;
                        <div @onclick="() => SelectEntry(entry)"
                             class="p-3 bg-[var(--bg-primary)] border cursor-pointer transition-all duration-100 steps-2 hover:bg-[var(--bg-secondary)] hover:border-[var(--border-active)]
                                    @(isSelected ? "border-[var(--accent-primary)] bg-[var(--accent-glow)]" : "border-[var(--border-subtle)]")">
                            <div class="flex items-center justify-between">
                                <span class="text-[9px] uppercase tracking-wider font-mono px-1.5 py-0.5
                                             @(entry.EntityType == "Character" ? "border border-[var(--accent-primary)] text-[var(--accent-primary)]" :
                                               entry.EntityType == "Location" ? "border border-[var(--border-active)] text-[var(--text-primary)]" :
                                               entry.EntityType == "Event" ? "border border-[var(--accent-warning)] text-[var(--accent-warning)]" :
                                               "border border-[var(--border-subtle)] text-[var(--text-disabled)]")">
                                    @entry.EntityType
                                </span>
                                @if (entry.Neo4jSynced)
                                {
                                    <span class="text-[9px] text-[var(--accent-primary)] font-mono uppercase">[ LINKED ]</span>
                                }
                            </div>
                            <h4 class="font-mono text-xs uppercase text-[var(--text-primary)] truncate mt-2 mb-1">@entry.Name</h4>
                            <p class="text-cyber-body text-xs line-clamp-2">@entry.Description</p>
                            @if (entry.Tags != null && entry.Tags.Count > 0)
                            {
                                <div class="flex flex-wrap gap-1 mt-2">
                                    @foreach (var tag in entry.Tags)
                                    {
                                        <span class="text-[9px] text-[var(--text-disabled)] font-mono border border-[var(--border-subtle)] px-1 bg-[var(--bg-secondary)]">#@tag</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            }
        </div>
    </div>

    <!-- Right Column: Detail / Edit panel -->
    <div class="lg:col-span-2 p-4 bg-[var(--bg-secondary)] border border-[var(--border-subtle)] flex flex-col h-full overflow-hidden">
        @if (_selectedEntry == null)
        {
            <div class="flex-1 flex flex-col items-center justify-center text-center">
                <span class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] mb-2">[ NO_SELECTION ]</span>
                <h3 class="text-cyber-title text-[var(--text-disabled)] uppercase mb-2">No Lore Selected</h3>
                <p class="text-cyber-body text-xs max-w-sm">
                    Select a lore card node from the directory to review its classifications, descriptions, and linked occurrences.
                </p>
            </div>
        }
        else
        {
            <div class="flex-1 overflow-y-auto pr-2 space-y-4">
                <!-- Header Block -->
                <div class="flex items-center justify-between border-b border-[var(--border-subtle)] pb-3">
                    <div>
                        <span class="text-cyber-metadata">SYS_LORE_DETAIL</span>
                        <h2 class="text-cyber-title uppercase mt-1">@_selectedEntry.Name</h2>
                    </div>
                    <button @onclick="DeleteEntryAsync" 
                            class="cyber-button text-xs py-1 px-3 border-[var(--accent-warning)] text-[var(--accent-warning)] hover:bg-[var(--accent-warning)] hover:text-[var(--bg-primary)]">
                        [ DELETE LORE ]
                    </button>
                </div>
 
                <!-- Fields Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-cyber-metadata text-[10px] block">Name / Key</label>
                        <input @bind="_selectedEntry.Name" 
                               class="cyber-input text-xs w-full bg-[var(--bg-primary)]" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-cyber-metadata text-[10px] block">Entity Classification</label>
                        <select @bind="_selectedEntry.EntityType" 
                                class="cyber-input text-xs w-full bg-[var(--bg-primary)]">
                            <option value="Character">Character</option>
                            <option value="Location">Location</option>
                            <option value="Event">Event</option>
                            <option value="Object">Object</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-cyber-metadata text-[10px] block">Tags (Comma separated)</label>
                    <input @bind="_tagsCsv" 
                           class="cyber-input text-xs w-full bg-[var(--bg-primary)]" />
                </div>

                <div class="space-y-1">
                    <label class="text-cyber-metadata text-[10px] block">Lore Description</label>
                    <textarea @bind="_selectedEntry.Description" rows="6"
                              class="cyber-input text-xs w-full bg-[var(--bg-primary)] font-mono resize-none"
                              placeholder="Write lore documentation..."></textarea>
                </div>

                <!-- Update Button -->
                <div class="flex justify-end pt-2">
                    <button @onclick="UpdateEntryAsync" 
                            class="cyber-button text-xs py-1.5 px-4">
                        [ SAVE LORE CHANGES ]
                    </button>
                </div>

                <!-- Appearances section (Neo4j linkage) -->
                <div class="border-t border-[var(--border-subtle)] pt-3">
                    <h3 class="text-cyber-title text-xs uppercase tracking-wider mb-3">Chapter Appearances (Neo4j Linkages)</h3>
                    @if (_loadingAppearances)
                    {
                        <p class="text-cyber-tech-mono text-xs text-[var(--text-disabled)] animate-pulse">Scanning manuscripts for mentions...</p>
                    }
                    else if (_appearances == null || _appearances.Count == 0)
                    {
                        <p class="text-cyber-body text-xs italic text-[var(--text-disabled)]">This entity has no tracked mentions in manuscripts. Use the exact entity name in your chapters to establish an active relationship in the narrative graph.</p>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs">
                            @foreach (var app in _appearances)
                            {
                                <div class="p-2 bg-[var(--bg-primary)] border border-[var(--border-subtle)] flex flex-col">
                                    <span class="text-[9px] uppercase tracking-wider text-[var(--accent-primary)] font-mono mb-0.5">@app.ManuscriptTitle</span>
                                    <span class="text-cyber-body text-xs truncate">@app.ChapterTitle</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private List<WikiEntry>? _entries;
    private bool _loading = true;

    // Filters and search
    private string _searchText = string.Empty;
    private string _filterType = "All";
    private readonly List<string> _entityTypes = new() { "All", "Character", "Location", "Event", "Object" };

    // Detail state
    private WikiEntry? _selectedEntry;
    private string _tagsCsv = string.Empty;
    private List<AppearanceRecord>? _appearances;
    private bool _loadingAppearances = false;

    // Create Form state
    private bool _showCreateForm = false;
    private string _newEntryName = string.Empty;
    private string _newEntryType = "Character";
    private string _newEntryDescription = string.Empty;
    private string _newEntryTags = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadEntriesAsync();
    }

    private async Task LoadEntriesAsync()
    {
        _loading = true;
        try
        {
            var result = await WikiService.GetEntriesAsync(ProjectId);
            _entries = result ?? new List<WikiEntry>();
        }
        finally
        {
            _loading = false;
        }
    }

    private List<WikiEntry> GetFilteredEntries()
    {
        if (_entries == null) return new List<WikiEntry>();

        return _entries.Where(e =>
        {
            var matchesType = _filterType == "All" || string.Equals(e.EntityType, _filterType, StringComparison.OrdinalIgnoreCase);
            var matchesSearch = string.IsNullOrEmpty(_searchText) ||
                                e.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                                e.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                                (e.Tags != null && e.Tags.Any(t => t.Contains(_searchText, StringComparison.OrdinalIgnoreCase)));
            return matchesType && matchesSearch;
        }).ToList();
    }

    private void SetFilterType(string type)
    {
        _filterType = type;
    }

    private void ShowCreateForm()
    {
        _showCreateForm = true;
        _newEntryName = string.Empty;
        _newEntryType = "Character";
        _newEntryDescription = string.Empty;
        _newEntryTags = string.Empty;
    }

    private void CancelCreateForm()
    {
        _showCreateForm = false;
    }

    private async Task CreateEntryAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEntryName)) return;

        var tagsList = _newEntryTags
            .Split(',')
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();

        var created = await WikiService.CreateEntryAsync(ProjectId, _newEntryName, _newEntryType, _newEntryDescription, tagsList);
        if (created != null)
        {
            await LoadEntriesAsync();
            _selectedEntry = created;
            _tagsCsv = string.Join(", ", created.Tags);
            await LoadAppearancesAsync(created.EntityId);
            _showCreateForm = false;
        }
    }

    private async Task SelectEntry(WikiEntry entry)
    {
        _selectedEntry = entry;
        _tagsCsv = entry.Tags != null ? string.Join(", ", entry.Tags) : string.Empty;
        await LoadAppearancesAsync(entry.EntityId);
    }

    private async Task LoadAppearancesAsync(string entityId)
    {
        _loadingAppearances = true;
        _appearances = null;
        try
        {
            _appearances = await WikiService.GetEntityAppearancesAsync(ProjectId, entityId);
        }
        catch (Exception)
        {
            _appearances = null;
        }
        finally
        {
            _loadingAppearances = false;
        }
    }

    private async Task UpdateEntryAsync()
    {
        if (_selectedEntry == null) return;

        var tagsList = _tagsCsv
            .Split(',')
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();

        var updated = await WikiService.UpdateEntryAsync(
            ProjectId,
            _selectedEntry.EntityId,
            _selectedEntry.Name,
            _selectedEntry.EntityType,
            _selectedEntry.Description,
            tagsList
        );

        if (updated != null)
        {
            await LoadEntriesAsync();
            _selectedEntry = updated;
            _tagsCsv = string.Join(", ", updated.Tags);
        }
    }

    private async Task DeleteEntryAsync()
    {
        if (_selectedEntry == null) return;

        var success = await WikiService.DeleteEntryAsync(ProjectId, _selectedEntry.EntityId);
        if (success)
        {
            _selectedEntry = null;
            await LoadEntriesAsync();
        }
    }
}
