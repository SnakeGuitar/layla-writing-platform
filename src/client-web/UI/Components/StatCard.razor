@* Tarjeta de métrica usada por el dashboard administrativo. *@
<div class="bg-base-gray-2 rounded-lg p-5 shadow flex flex-col gap-2">
    <span class="text-stone-400 text-xs uppercase tracking-[0.15em]">@Label</span>
    <span class="text-stone-100 text-3xl font-light tabular-nums">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int Value { get; set; }
}
