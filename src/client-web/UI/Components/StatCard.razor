@* Monolithic technical metric widget *@
<div class="cyber-panel flex flex-col gap-1.5">
    <span class="text-cyber-metadata">@Label</span>
    <span class="text-cyber-display tabular-nums">@Value</span>
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int Value { get; set; }
}
